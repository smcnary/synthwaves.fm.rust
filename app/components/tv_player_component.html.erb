<div id="tv-player" data-turbo-permanent
     data-controller="hls-player retro-tv"
     data-retro-tv-channels-value="[]">
  <div data-hls-player-target="container" class="hidden container mx-auto px-5 py-4">
    <div class="max-w-4xl mx-auto bg-gradient-to-b from-gray-700 via-gray-800 to-gray-900 rounded-2xl p-4 md:p-6 shadow-2xl border border-gray-600 relative"
         tabindex="0" data-action="keydown->retro-tv#keydown">
      <%# Close button %>
      <button type="button" data-action="hls-player#close"
              class="absolute top-2 right-2 z-10 w-8 h-8 flex items-center justify-center rounded-full bg-black/50 text-gray-400 hover:text-white transition-colors cursor-pointer">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      <%# Screen + side control panel %>
      <div class="flex gap-4">
        <%# CRT screen %>
        <div class="flex-1 relative bg-black rounded-xl overflow-hidden aspect-video crt-screen"
             data-hls-player-target="videoWrapper">
          <video data-hls-player-target="video"
                 class="w-full h-full"
                 controls
                 playsinline></video>
          <div data-hls-player-target="loading"
               class="absolute inset-0 flex items-center justify-center bg-black/50 hidden">
            <div class="w-8 h-8 border-2 border-neon-cyan border-t-transparent rounded-full animate-spin"></div>
          </div>
          <div data-hls-player-target="error"
               class="absolute inset-0 flex items-center justify-center bg-black/80 text-red-400 text-sm px-4 text-center hidden">
          </div>
          <button data-hls-player-target="ccButton"
                  data-action="click->hls-player#toggleCC"
                  class="hidden absolute bottom-12 right-3 z-10 px-2 py-1 rounded text-xs font-bold border bg-black/70 backdrop-blur-sm transition-all duration-150 cursor-pointer border-gray-500 text-gray-400"
                  title="Toggle Closed Captions">
            CC
          </button>
        </div>
        <%# Side control panel (desktop only) %>
        <div class="hidden md:flex md:flex-col w-16 items-center justify-center gap-4">
          <%# Power LED %>
          <div class="w-2 h-2 rounded-full bg-red-500 shadow-[0_0_6px_rgba(239,68,68,0.7)] mb-2"></div>
          <%# Channel up %>
          <button type="button" data-action="click->retro-tv#channelUp"
                  class="w-10 h-10 rounded-full bg-gray-600 border-2 border-gray-500 hover:border-neon-cyan hover:bg-gray-500 active:shadow-inner transition-colors flex items-center justify-center cursor-pointer"
                  title="Channel up">
            <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20"><path d="M10 5l6 8H4l6-8z"/></svg>
          </button>
          <%# Channel number %>
          <div data-retro-tv-target="channelNumber" class="font-mono text-neon-cyan text-xl tracking-wider">--</div>
          <%# Channel down %>
          <button type="button" data-action="click->retro-tv#channelDown"
                  class="w-10 h-10 rounded-full bg-gray-600 border-2 border-gray-500 hover:border-neon-cyan hover:bg-gray-500 active:shadow-inner transition-colors flex items-center justify-center cursor-pointer"
                  title="Channel down">
            <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20"><path d="M10 15l6-8H4l6 8z"/></svg>
          </button>
        </div>
      </div>
      <%# Info strip %>
      <div class="mt-3 flex items-center gap-3">
        <div data-retro-tv-target="channelLogo" class="w-8 h-8 rounded bg-gray-700 flex items-center justify-center overflow-hidden flex-shrink-0"></div>
        <div class="flex-1 min-w-0">
          <div data-hls-player-target="channelName" data-retro-tv-target="channelName" class="text-sm font-medium text-white truncate"></div>
          <div class="flex items-center gap-2 mt-0.5">
            <span class="text-xs text-neon-cyan uppercase tracking-wide">Now:</span>
            <span data-retro-tv-target="nowPlaying" class="text-xs text-gray-400 truncate">No schedule info</span>
          </div>
        </div>
        <div class="flex items-center gap-3 flex-shrink-0">
          <div class="hidden w-24 h-1.5 bg-gray-700 rounded-full overflow-hidden">
            <div data-retro-tv-target="progressBar" class="h-full bg-neon-cyan rounded-full transition-all" style="width: 0%"></div>
          </div>
          <span data-retro-tv-target="timeLeft" class="hidden text-[10px] text-gray-500 whitespace-nowrap"></span>
        </div>
      </div>
      <%# Mobile channel buttons %>
      <div class="mt-3 flex items-center justify-center gap-4 md:hidden">
        <button type="button" data-action="click->retro-tv#channelDown"
                class="px-4 py-2 text-sm rounded-lg bg-gray-600 border border-gray-500 text-gray-300 hover:border-neon-cyan hover:text-neon-cyan active:shadow-inner transition-colors cursor-pointer">
          CH &minus;
        </button>
        <div data-retro-tv-target="channelNumber" class="font-mono text-neon-cyan text-lg tracking-wider w-8 text-center">--</div>
        <button type="button" data-action="click->retro-tv#channelUp"
                class="px-4 py-2 text-sm rounded-lg bg-gray-600 border border-gray-500 text-gray-300 hover:border-neon-cyan hover:text-neon-cyan active:shadow-inner transition-colors cursor-pointer">
          CH +
        </button>
      </div>
    </div>
  </div>
</div>
