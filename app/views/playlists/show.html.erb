<% content_for :meta_title, "#{@playlist.name} — synthwaves.fm" %>
<% content_for :meta_description, "#{pluralize(@total_track_count, 'track')} · #{format_duration(@total_duration)} on synthwaves.fm" %>
<% if (cover_pt = @playlist.playlist_tracks.joins(track: { album: { cover_image_attachment: :blob } }).first) %>
  <% content_for :meta_image, og_image_url_for(cover_pt.track.album.cover_image) %>
<% end %>
<% content_for :meta_type, "music.playlist" %>

<div class="w-full" data-controller="play-all">
  <div class="mb-6">
    <%= render Button::Component.new(label: "← Playlists", behavior: :navigation, link_url: playlists_path, style: :link) %>
  </div>

  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 sm:gap-0 mb-6">
    <div>
      <h1 class="text-3xl font-bold font-display"><%= @playlist.name %></h1>
      <p class="text-sm text-gray-400 mt-1"><%= pluralize(@total_track_count, "track") %> · <%= format_duration(@total_duration) %></p>
    </div>
    <div class="flex flex-wrap gap-2" data-controller="clipboard" data-clipboard-content-value="<%= playlist_tracks_as_text(@playlist.playlist_tracks.includes(track: [:artist]).order(:position)) %>">
      <%= render Button::Component.new(data: { action: "play-all#playAll" }, extra_classes: "gap-1") do %>
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.84A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.27l9.344-5.891a1.5 1.5 0 000-2.538L6.3 2.84z"/></svg>
        Play All
      <% end %>
      <%= render Button::Component.new(style: :secondary, data: { action: "play-all#shuffleAll" }, extra_classes: "gap-1") do %>
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M15.312 3.752a.75.75 0 01.937-.187l.084.058 1.5 1.25a.75.75 0 01.084 1.121l-.084.079-1.5 1.25a.75.75 0 01-1.04-1.065l.056-.056.251-.21H14.5a2.5 2.5 0 00-1.967.96l-.103.145-1.18 1.853-1.25-1.96 .47-.738A4 4 0 0114.5 3.002h1.1l-.251-.21a.75.75 0 01-.098-1l.06-.07zM3.75 4a.75.75 0 01.102 1.493L3.75 5.5H2.75a.75.75 0 01-.102-1.493L2.75 4h1zm12.562 9.248a.75.75 0 01.937-.187l.084.058 1.5 1.25a.75.75 0 01.084 1.121l-.084.079-1.5 1.25a.75.75 0 01-1.04-1.065l.056-.056.251-.21H14.5a4 4 0 01-3.03-1.388l-.16-.197-.56-.78 1.25-1.962.43.675A2.5 2.5 0 0014.5 13h1.1l-.251-.21a.75.75 0 01-.098-1l.06-.07zM3.75 14a.75.75 0 01.102 1.493L3.75 15.5H2.75a.75.75 0 01-.102-1.493L2.75 14h1z" clip-rule="evenodd"/></svg>
        Shuffle All
      <% end %>
      <%= button_to "Download", downloads_path(downloadable_type: "Playlist", downloadable_id: @playlist.id), class: "px-4 py-2 bg-gray-700 text-white rounded-lg hover:bg-gray-600" %>
      <%= render Button::Component.new(label: "Copy track list", style: :secondary, data: { clipboard_target: "button", action: "clipboard#copy" }) %>
      <%= render Button::Component.new(label: "Edit", behavior: :navigation, link_url: edit_playlist_path(@playlist), style: :secondary) %>
      <%= render "playlists/merge_menu", playlist: @playlist %>
      <%= button_to "Delete", playlist_path(@playlist), method: :delete, data: { turbo_confirm: "Delete this playlist?" }, class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700" %>
    </div>
  </div>

  <% if Flipper.enabled?(:radio_stations, Current.user) %>
    <% if @playlist.radio_station %>
      <div class="mb-6 bg-gray-800 rounded-lg border border-gray-700 p-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-neon-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728M9.172 14.828a4 4 0 010-5.656m5.656 0a4 4 0 010 5.656M12 12h.01"/></svg>
          <div>
            <span class="text-white font-medium">Radio Station</span>
            <%= render "radio_stations/status_badge", station: @playlist.radio_station %>
          </div>
        </div>
        <%= link_to "Manage", radio_station_path(@playlist.radio_station), class: "px-3 py-1.5 bg-gray-700 text-gray-300 rounded-lg text-sm hover:bg-gray-600" %>
      </div>
    <% else %>
      <div class="mb-6">
        <%= button_to radio_stations_path(playlist_id: @playlist.id), class: "inline-flex items-center gap-2 px-4 py-2 bg-gray-700 text-gray-300 rounded-lg hover:bg-gray-600 text-sm" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728M9.172 14.828a4 4 0 010-5.656m5.656 0a4 4 0 010 5.656M12 12h.01"/></svg>
          Create Radio Station
        <% end %>
      </div>
    <% end %>
  <% end %>

  <turbo-frame id="playlist-tracks" data-turbo-action="advance">
    <form action="<%= playlist_path(@playlist) %>" method="get" data-controller="search" data-search-target="form" class="mb-4">
      <input type="text" name="q" value="<%= @query %>" placeholder="Search tracks..."
             class="w-full rounded-lg bg-gray-800 border-gray-700 text-white text-lg px-4 py-3 focus:outline-neon-cyan"
             data-search-target="input" data-action="input->search#submit">
    </form>

    <% if @playlist_tracks.any? %>
      <div class="bg-gray-800 rounded-lg border border-gray-700">
        <% @playlist_tracks.each do |pt| %>
          <%= render TrackRow::Component.new(track: pt.track, number: pt.position, link_title: true, link_subtitle: true) do |c| %>
            <% c.with_trailing do %>
              <% if pt.track.audio_file.attached? %>
                <%= link_to download_track_path(pt.track), class: "text-gray-400 hover:text-neon-cyan", title: "Download" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                <% end %>
              <% end %>
              <%= render "favorites/button", favorable: pt.track, favorited: @favorited_track_ids.include?(pt.track.id) %>
              <%= button_to playlist_track_path(@playlist, pt),
                    method: :delete,
                    class: "text-gray-400 hover:text-red-600",
                    title: "Remove from playlist" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>
      <% if @pagy.pages > 1 %>
        <div class="mt-6 flex justify-center">
          <%== @pagy.series_nav %>
        </div>
      <% end %>
    <% else %>
      <p class="text-gray-400 py-8 text-center">No tracks found<%= " for \"#{@query}\"" if @query.present? %>.</p>
    <% end %>
  </turbo-frame>
</div>
