<%= form_with model: playlist, class: "space-y-4" do |f| %>
  <% if playlist.errors.any? %>
    <div class="bg-red-900/20 border border-red-800 rounded-lg p-4">
      <ul class="text-sm text-red-400">
        <% playlist.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-400 mb-1" %>
    <%= f.text_field :name, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan" %>
  </div>

  <div>
    <%= f.submit class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink cursor-pointer" %>
    <%= link_to "Cancel", playlists_path, class: "px-4 py-2 text-gray-400 hover:text-neon-cyan" %>
  </div>
<% end %>
