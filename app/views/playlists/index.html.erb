<div class="w-full">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold font-display">Playlists</h1>
    <%= link_to "New Playlist", new_playlist_path, class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink" %>
  </div>

  <div data-controller="search" class="mb-6">
    <%= form_with url: playlists_path, method: :get, data: { turbo_frame: "playlists-list", search_target: "form", action: "input->search#submit" } do |f| %>
      <div class="flex flex-col sm:flex-row gap-3">
        <input type="text" name="q" value="<%= @query %>" placeholder="Search playlists..."
               class="flex-1 rounded-lg bg-gray-800 border-gray-700 text-white text-lg px-4 py-3 focus:outline-neon-cyan"
               data-search-target="input" autofocus>

        <div class="flex items-center gap-3">
          <label for="sort" class="text-sm text-gray-500">Sort by</label>
          <select name="sort" id="sort" data-action="change->search#submit" class="text-sm rounded-md border-gray-600 bg-gray-700 text-white">
            <% Playlist::SORT_OPTIONS.each do |value, label| %>
              <option value="<%= value %>" <%= "selected" if value == @sort %>><%= label %></option>
            <% end %>
          </select>

          <select name="direction" id="direction" data-action="change->search#submit" class="text-sm rounded-md border-gray-600 bg-gray-700 text-white">
            <option value="asc" <%= "selected" if @direction == "asc" %>>Ascending</option>
            <option value="desc" <%= "selected" if @direction == "desc" %>>Descending</option>
          </select>
        </div>
      </div>
    <% end %>
  </div>

  <turbo-frame id="playlists-list" data-turbo-action="replace">
    <% if @playlists.any? %>
      <div class="space-y-2">
        <% @playlists.each do |playlist| %>
          <div class="bg-gray-800 rounded-lg border border-gray-700 p-4 flex items-center justify-between hover:shadow transition-shadow">
            <%= link_to playlist_path(playlist), class: "flex-1 min-w-0", data: { turbo_frame: "_top" } do %>
              <div class="font-medium text-white hover:text-neon-cyan truncate"><%= playlist.name %></div>
              <div class="text-sm text-gray-500"><%= pluralize(playlist.playlist_tracks_count, "track") %></div>
            <% end %>
            <div class="flex items-center gap-3 flex-shrink-0 ml-4">
              <%= link_to edit_playlist_path(playlist), class: "text-gray-400 hover:text-neon-cyan", title: "Edit" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              <% end %>
              <%= button_to playlist_path(playlist), method: :delete, data: { turbo_confirm: "Delete \"#{playlist.name}\"?" }, class: "text-gray-400 hover:text-red-500", title: "Delete" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-6 flex justify-center">
        <%== @pagy.series_nav %>
      </div>
    <% else %>
      <p class="text-gray-500">No playlists found<%= " for \"#{@query}\"" if @query.present? %>.</p>
    <% end %>
  </turbo-frame>
</div>
