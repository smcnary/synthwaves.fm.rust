<div class="w-full max-w-2xl mx-auto">
  <div class="mb-4">
    <%= link_to "&larr; Back to stations".html_safe, internet_radio_stations_path, class: "text-sm text-gray-400 hover:text-neon-cyan transition-colors" %>
  </div>

  <div class="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden">
    <div class="flex flex-col sm:flex-row gap-6 p-6">
      <!-- Station Logo -->
      <div class="w-32 h-32 flex-shrink-0 bg-gray-700 rounded-lg overflow-hidden">
        <% if @station.display_favicon_url.present? %>
          <img src="<%= @station.display_favicon_url %>" alt="<%= @station.name %>" class="w-full h-full object-contain p-2">
        <% else %>
          <div class="w-full h-full flex items-center justify-center">
            <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728M9.172 14.828a4 4 0 010-5.656m5.656 0a4 4 0 010 5.656M12 12h.01"/>
            </svg>
          </div>
        <% end %>
      </div>

      <!-- Station Info -->
      <div class="flex-1 min-w-0">
        <h1 class="text-2xl font-bold font-display text-white"><%= @station.name %></h1>

        <div class="mt-3 space-y-1 text-sm text-gray-400">
          <% if @station.country.present? %>
            <p>Country: <span class="text-white"><%= @station.country %></span></p>
          <% end %>
          <% if @station.language.present? %>
            <p>Language: <span class="text-white"><%= @station.language %></span></p>
          <% end %>
          <% if @station.codec.present? %>
            <p>Codec: <span class="text-white"><%= @station.codec %><%= " / #{@station.bitrate}kbps" if @station.bitrate&.positive? %></span></p>
          <% end %>
          <% if @station.tags.present? %>
            <div class="flex flex-wrap gap-1 mt-2">
              <% @station.tags.split(",").first(10).each do |tag| %>
                <%= link_to tag.strip, internet_radio_stations_path(tag: tag.strip), class: "inline-block px-2 py-0.5 text-xs rounded-full bg-gray-700 text-gray-500 hover:bg-gray-600 transition-colors" %>
              <% end %>
            </div>
          <% end %>
        </div>

        <% if @station.homepage_url.present? %>
          <p class="mt-2 text-sm">
            <%= link_to "Visit homepage", @station.homepage_url, target: "_blank", rel: "noopener", class: "text-neon-cyan hover:underline" %>
          </p>
        <% end %>
      </div>
    </div>

    <!-- Actions -->
    <div class="border-t border-gray-700 p-6 flex items-center gap-4">
      <button type="button"
              class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-white bg-neon-pink rounded-lg hover:bg-neon-pink/80 transition-colors"
              data-controller="song-row"
              data-song-row-track-id-value="0"
              data-song-row-title-value="<%= @station.name %>"
              data-song-row-artist-value="Internet Radio"
              data-song-row-stream-url-value="<%= @station.needs_proxy? ? internet_radio_station_stream_path(@station) : @station.stream_url %>"
              data-song-row-is-live-value="true"
              data-action="click->song-row#play">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/></svg>
        Play
      </button>

      <div id="favorite_internetradiostation_<%= @station.id %>">
        <%= render partial: "favorites/button", locals: { favorable: @station, favorited: @is_favorited } %>
      </div>

      <div class="ml-auto flex items-center gap-2">
        <%= link_to "Edit", edit_internet_radio_station_path(@station), class: "px-4 py-2 text-sm font-medium text-white bg-gray-700 rounded-lg hover:bg-gray-600 transition-colors" %>
        <%= button_to "Delete", internet_radio_station_path(@station), method: :delete, data: { turbo_confirm: "Remove this station?" }, class: "px-4 py-2 text-sm font-medium text-red-400 bg-gray-700 rounded-lg hover:bg-gray-600 transition-colors" %>
      </div>
    </div>
  </div>
</div>
