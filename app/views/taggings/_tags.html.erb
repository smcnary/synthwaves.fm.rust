<div id="tags-<%= taggable.class.name.downcase %>-<%= taggable.id %>" class="flex flex-wrap items-center gap-2">
  <% taggable.taggings.includes(:tag).each do |tagging| %>
    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium
                 <%= tagging.tag.tag_type == 'genre' ? 'bg-neon-cyan/20 text-neon-cyan' : 'bg-neon-purple/20 text-neon-purple' %>">
      <%= tagging.tag.name %>
      <%= button_to tagging_path(tagging), method: :delete, class: "hover:text-white transition-colors", data: { turbo_method: :delete } do %>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      <% end %>
    </span>
  <% end %>

  <details class="relative inline-block">
    <summary class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-700 text-gray-400 hover:text-white cursor-pointer list-none transition-colors">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add tag
    </summary>
    <div class="absolute left-0 top-full mt-1 z-50 bg-gray-800 rounded-lg border border-gray-700 p-3 shadow-lg w-56">
      <%= form_with url: taggings_path, class: "space-y-2" do |f| %>
        <%= f.hidden_field :taggable_type, name: "tagging[taggable_type]", value: taggable.class.name %>
        <%= f.hidden_field :taggable_id, name: "tagging[taggable_id]", value: taggable.id %>
        <input type="text" name="tagging[name]" placeholder="Tag name..." required
               class="w-full px-2 py-1 text-xs rounded border border-gray-600 bg-gray-900 text-white focus:outline-none focus:ring-1 focus:ring-neon-cyan">
        <div class="flex gap-2">
          <label class="flex items-center gap-1 text-xs text-gray-400">
            <input type="radio" name="tagging[tag_type]" value="genre" checked class="text-neon-cyan"> Genre
          </label>
          <label class="flex items-center gap-1 text-xs text-gray-400">
            <input type="radio" name="tagging[tag_type]" value="mood" class="text-neon-purple"> Mood
          </label>
        </div>
        <button type="submit" class="w-full px-2 py-1 text-xs font-medium rounded bg-neon-cyan/20 text-neon-cyan hover:bg-neon-cyan/30 transition-colors">
          Add
        </button>
      <% end %>
    </div>
  </details>
</div>
