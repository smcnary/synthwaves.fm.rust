<turbo-frame id="youtube-search-results">
  <% if @error.present? %>
    <p class="text-red-400 text-sm mt-2"><%= @error %></p>
  <% elsif @query.present? && @results.empty? %>
    <p class="text-gray-400 text-sm mt-2">No results found for "<%= @query %>".</p>
  <% elsif @results.any? %>
    <ul class="mt-3 space-y-2">
      <% @results.each do |result| %>
        <li>
          <button type="button"
            class="w-full flex items-center gap-3 p-2 rounded-lg hover:bg-gray-700 text-left transition-colors"
            data-action="click->youtube-search#selectResult"
            data-youtube-search-url-param="https://www.youtube.com/watch?v=<%= result[:video_id] %>">
            <% if result[:thumbnail_url].present? %>
              <img src="<%= result[:thumbnail_url] %>" alt="" class="w-20 h-auto rounded flex-shrink-0" loading="lazy">
            <% else %>
              <div class="w-20 h-12 bg-gray-700 rounded flex-shrink-0"></div>
            <% end %>
            <div class="min-w-0">
              <p class="text-white text-sm font-medium truncate"><%= result[:title] %></p>
              <p class="text-gray-400 text-xs truncate"><%= result[:channel_name] %></p>
            </div>
          </button>
        </li>
      <% end %>
    </ul>
  <% end %>
</turbo-frame>
