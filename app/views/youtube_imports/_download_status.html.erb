<div id="media-download-<%= type %>-<%= record.id %>" class="bg-gray-800 border border-gray-700 rounded-lg p-3 shadow-lg max-w-sm">
  <div class="flex items-center gap-2">
    <% case record.download_status %>
    <% when "downloading" %>
      <svg class="w-4 h-4 text-neon-cyan animate-spin" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <span class="text-sm text-white">Downloading <%= type %>...</span>
    <% when "completed" %>
      <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
      </svg>
      <span class="text-sm text-white">Download complete!</span>
    <% when "failed" %>
      <svg class="w-4 h-4 text-red-400" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
      <span class="text-sm text-red-400">Download failed</span>
    <% end %>
  </div>
  <p class="text-xs text-gray-500 mt-1 truncate"><%= record.respond_to?(:title) ? record.title : "" %></p>
</div>
