<div class="p-4 flex items-center justify-between">
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-3">
      <h3 class="text-sm font-medium text-gray-900 dark:text-white truncate"><%= api_key.name %></h3>
      <% if api_key.expired? %>
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
          Expired
        </span>
      <% else %>
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
          Active
        </span>
      <% end %>
    </div>
    <div class="mt-1 text-sm text-gray-500 dark:text-gray-400">
      <span class="font-mono"><%= api_key.client_id %></span>
    </div>
    <div class="mt-1 text-xs text-gray-400 dark:text-gray-500 space-x-4">
      <span>Created <%= time_ago_in_words(api_key.created_at) %> ago</span>
      <% if api_key.last_used_at %>
        <span>Last used <%= time_ago_in_words(api_key.last_used_at) %> ago<%= " from #{api_key.last_used_ip}" if api_key.last_used_ip %></span>
      <% else %>
        <span>Never used</span>
      <% end %>
      <% if api_key.expires_at %>
        <span>Expires <%= api_key.expires_at.strftime("%b %d, %Y") %></span>
      <% end %>
    </div>
  </div>
  <div class="ml-4">
    <%= button_to "Revoke", api_key_path(api_key), method: :delete, data: { turbo_confirm: "Are you sure you want to revoke this API key? This cannot be undone." }, class: "text-sm text-red-600 hover:text-red-500 dark:text-red-400 dark:hover:text-red-300" %>
  </div>
</div>
