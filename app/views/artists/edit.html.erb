<div class="w-full max-w-lg">
  <h1 class="text-3xl font-bold font-display mb-6">Edit Artist</h1>

  <%= form_with model: @artist, class: "space-y-5" do |f| %>
    <% if @artist.errors.any? %>
      <div class="bg-red-900/20 border border-red-800 rounded-lg p-4">
        <ul class="text-sm text-red-400">
          <% @artist.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.text_field :name, class: "w-full rounded-lg bg-gray-800 border border-gray-700 px-3 py-2 text-white focus:outline-neon-cyan" %>
    </div>

    <div>
      <%= f.label :category, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.select :category, Artist::CATEGORIES.map { |c| [c.titleize, c] }, {}, class: "w-full rounded-lg bg-gray-800 border border-gray-700 px-3 py-2 text-white focus:outline-neon-cyan" %>
    </div>

    <div>
      <%= f.submit "Save", class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink cursor-pointer" %>
      <%= link_to "Cancel", artist_path(@artist), class: "px-4 py-2 text-gray-400 hover:text-neon-cyan" %>
    </div>
  <% end %>
</div>
