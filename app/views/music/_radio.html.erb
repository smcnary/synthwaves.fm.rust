<%= render CollectionLayoutComponent.new(
  collection: @radio_stations,
  page_key: "music-radio",
  search: false,
  view_toggle: true,
  container_classes: "grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 collection-grid",
  empty_label: "radio stations"
) do |c| %>
  <% c.with_actions do %>
    <%= link_to "Add Station", new_radio_station_path, class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink text-sm font-medium", data: { turbo_frame: "_top" } %>
  <% end %>
  <% c.with_empty_state do %>
    <div class="text-center py-16 text-gray-400">
      <svg class="w-16 h-16 mx-auto mb-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728M9.172 14.828a4 4 0 010-5.656m5.656 0a4 4 0 010 5.656M12 12h.01"/>
      </svg>
      <p class="text-lg mb-2">No radio stations yet</p>
      <p class="mb-4">Add a YouTube live stream or internet radio station to get started.</p>
      <%= link_to "Add Station", new_radio_station_path, class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink", data: { turbo_frame: "_top" } %>
    </div>
  <% end %>
  <% @radio_stations.each do |station| %>
    <div class="collection-card">
      <%= render "radio_stations/radio_station", station: station %>
    </div>
  <% end %>
<% end %>
