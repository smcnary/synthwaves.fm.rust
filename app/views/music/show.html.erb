<div class="w-full">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold font-display">Music</h1>
    <%= link_to new_track_path, class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink text-sm font-medium" do %>
      Upload
    <% end %>
  </div>

  <%# Tabs %>
  <div class="flex gap-1 mb-6 border-b border-gray-700">
    <% [["artists", "Artists"], ["albums", "Albums"], ["tracks", "Tracks"], ["podcasts", "Podcasts"]].each do |key, label| %>
      <%= link_to label, music_path(tab: key),
            class: "px-4 py-2.5 text-sm font-medium transition-colors -mb-px #{@tab == key ? 'text-neon-cyan border-b-2 border-neon-cyan' : 'text-gray-400 hover:text-white'}",
            data: { turbo_frame: "music-content" } %>
    <% end %>
  </div>

  <turbo-frame id="music-content" data-turbo-action="advance">
    <%= render "music/#{@tab}" %>
  </turbo-frame>
</div>
