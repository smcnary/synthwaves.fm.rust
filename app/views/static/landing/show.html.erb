<% content_for :title, "Groovy Tunes - Welcome" %>

<!-- Hero Section -->
<section class="min-h-screen flex flex-col relative overflow-hidden retro-grid">
  <!-- Auth Bar -->
  <nav class="w-full py-4 px-6">
    <div class="max-w-7xl mx-auto flex justify-end items-center gap-4">
      <%= link_to "Log In", new_session_path, class: "text-gray-400 hover:text-neon-cyan font-medium transition-colors" %>
      <%= link_to "Sign Up", new_registration_path, class: "bg-sunset-gradient hover:shadow-neon-pink text-white px-4 py-2 rounded-lg font-medium transition-shadow" %>
    </div>
  </nav>

  <!-- Hero Content -->
  <div class="flex-1 flex flex-col items-center justify-center px-6 pb-16">
    <!-- Logo -->
    <div class="mb-6">
      <div class="w-20 h-20 bg-sunset-gradient rounded-2xl flex items-center justify-center shadow-neon-pink">
        <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
    </div>

    <!-- Title -->
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-center mb-4">
      <span class="font-display text-sunset">Groovy Tunes</span>
    </h1>

    <!-- Tagline -->
    <p class="text-xl md:text-2xl text-gray-500 text-center mb-8 max-w-2xl">
      Build something amazing with Rails
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4">
      <%= link_to new_registration_path, class: "bg-sunset-gradient hover:shadow-neon-pink text-white px-8 py-3 rounded-lg font-semibold text-lg transition-shadow shadow-lg" do %>
        Get Started Free
      <% end %>
      <a href="#features" class="bg-gray-800 border border-neon-cyan/30 hover:border-neon-cyan/60 text-white px-8 py-3 rounded-lg font-semibold text-lg transition-colors">
        Learn More
      </a>
    </div>
  </div>
</section>

<!-- Features Section -->
<section id="features" class="py-20 px-6 bg-gray-800">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 font-display text-white">Features</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Feature 1 -->
      <div class="text-center">
        <div class="w-16 h-16 bg-neon-cyan/10 border border-neon-cyan/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-neon-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-2 text-white">Fast</h3>
        <p class="text-gray-500">Lightning-fast performance with modern Rails.</p>
      </div>

      <!-- Feature 2 -->
      <div class="text-center">
        <div class="w-16 h-16 bg-laser-green/10 border border-laser-green/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-laser-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-2 text-white">Secure</h3>
        <p class="text-gray-500">Built-in authentication and security best practices.</p>
      </div>

      <!-- Feature 3 -->
      <div class="text-center">
        <div class="w-16 h-16 bg-neon-purple/10 border border-neon-purple/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-neon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-2 text-white">Responsive</h3>
        <p class="text-gray-500">Fully responsive design that works on any device.</p>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="py-8 px-6 bg-gray-900 border-t border-neon-purple/20">
  <div class="max-w-7xl mx-auto text-center">
    <p class="text-gray-500">
      &copy; <%= Date.current.year %> Groovy Tunes. Built with Ruby on Rails.
    </p>
  </div>
</footer>
