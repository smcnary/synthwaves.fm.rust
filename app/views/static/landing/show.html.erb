<% content_for :title, "Groovy Tunes - Welcome" %>

<!-- Hero Section -->
<section class="min-h-screen flex flex-col relative overflow-hidden">
  <!-- Auth Bar -->
  <nav class="w-full py-4 px-6">
    <div class="max-w-7xl mx-auto flex justify-end items-center gap-4">
      <%= link_to "Log In", new_session_path, class: "text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white font-medium transition-colors" %>
      <%= link_to "Sign Up", new_registration_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
    </div>
  </nav>

  <!-- Hero Content -->
  <div class="flex-1 flex flex-col items-center justify-center px-6 pb-16">
    <!-- Logo -->
    <div class="mb-6">
      <div class="w-20 h-20 bg-gradient-to-br from-blue-500 to-blue-700 rounded-2xl flex items-center justify-center shadow-lg">
        <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
    </div>

    <!-- Title -->
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-center mb-4">
      <span class="text-blue-600 dark:text-blue-500">Groovy Tunes</span>
    </h1>

    <!-- Tagline -->
    <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 text-center mb-8 max-w-2xl">
      Build something amazing with Rails
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4">
      <%= link_to new_registration_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg font-semibold text-lg transition-colors shadow-lg hover:shadow-xl" do %>
        Get Started Free
      <% end %>
      <a href="#features" class="bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-900 dark:text-white px-8 py-3 rounded-lg font-semibold text-lg transition-colors">
        Learn More
      </a>
    </div>
  </div>
</section>

<!-- Features Section -->
<section id="features" class="py-20 px-6 bg-gray-50 dark:bg-gray-800">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Features</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Feature 1 -->
      <div class="text-center">
        <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-2">Fast</h3>
        <p class="text-gray-600 dark:text-gray-400">Lightning-fast performance with modern Rails.</p>
      </div>

      <!-- Feature 2 -->
      <div class="text-center">
        <div class="w-16 h-16 bg-green-100 dark:bg-green-900 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-2">Secure</h3>
        <p class="text-gray-600 dark:text-gray-400">Built-in authentication and security best practices.</p>
      </div>

      <!-- Feature 3 -->
      <div class="text-center">
        <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-2">Responsive</h3>
        <p class="text-gray-600 dark:text-gray-400">Fully responsive design that works on any device.</p>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="py-8 px-6 bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700">
  <div class="max-w-7xl mx-auto text-center">
    <p class="text-gray-600 dark:text-gray-400">
      &copy; <%= Date.current.year %> Groovy Tunes. Built with Ruby on Rails.
    </p>
  </div>
</footer>
