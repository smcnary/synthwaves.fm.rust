<% content_for :title, "synthwaves.fm — Your Media, Your Server, Your Rules" %>
<% content_for :meta_title, "synthwaves.fm — Your Media, Your Server, Your Rules" %>
<% content_for :meta_description, "Self-hosted media streaming that puts you in control. Music, live TV, podcasts, and radio — no subscriptions, no algorithms, no compromises." %>
<!-- Hero Section -->
<section class="min-h-screen flex flex-col relative overflow-hidden">
  <!-- Hero background image -->
  <%= image_tag "hero2.webp", class: "absolute inset-0 w-full h-full object-cover object-center", alt: "" %>
  <%# <div class="absolute inset-0 bg-gradient-to-b from-gray-900/70 via-gray-900/40 to-gray-900/80"></div> %>
  <!-- Auth Bar -->
  <nav class="relative z-10 w-full py-4 px-4 sm:py-5 sm:px-6">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <%= render(Logo::Component.new(size: :md, icon: true, text: false)) %>
      <div class="flex items-center gap-2 sm:gap-4">
        <%= link_to "Radio", public_radio_stations_path, class: "text-gray-400 hover:text-neon-cyan transition-colors text-sm font-medium" %>
        <a href="https://github.com/leopolicastro/synthwaves.fm" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-neon-cyan transition-colors" aria-label="GitHub">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <%= render Button::Component.new(label: "Log In", behavior: :navigation, link_url: new_session_path, style: :link) %>
        <% if Flipper.enabled?(:open_registration) %>
          <%= render Button::Component.new(label: "Sign Up", behavior: :navigation, link_url: new_registration_path, style: :gradient) %>
        <% end %>
      </div>
    </div>
  </nav>
  <!-- Hero Content -->
  <div class="relative z-10 flex-1 flex flex-col items-center justify-start pt-[10vh] sm:pt-[15vh] px-4 sm:px-6 pb-10 sm:pb-20">
    <div class="bg-gray-900/80 backdrop-blur-sm rounded-2xl px-6 py-8 sm:px-10 sm:py-10 flex flex-col items-center">
      <!-- Title -->
      <h1 class="text-center mb-4 sm:mb-6 leading-tight">
        <%= render(Logo::Component.new(size: :lg)) %>
      </h1>
      <!-- Tagline -->
      <p class="text-xl md:text-2xl text-center mb-4 max-w-3xl leading-relaxed">
        <span class="text-neon-pink">Self-hosted media streaming</span>
        <span class="text-white"> that puts you in control.</span>
      </p>
      <p class="text-lg text-center mb-6 sm:mb-10 max-w-2xl">
        <span class="text-neon-cyan">Your music.</span>
        <span class="text-neon-pink">Your TV.</span>
        <span class="text-neon-purple">Your server.</span>
        <span class="text-white/80">No subscriptions, no algorithms, no compromises.</span>
      </p>
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4">
        <% if Flipper.enabled?(:open_registration) %>
          <%= render Button::Component.new(label: "Start Listening", behavior: :navigation, link_url: new_registration_path, style: :gradient, extra_classes: "shadow-lg") %>
        <% end %>
        <a href="#features" class="bg-gray-800/60 backdrop-blur border border-neon-cyan/30 hover:border-neon-cyan/60 hover:shadow-neon-cyan text-neon-cyan px-8 py-3.5 sm:px-10 sm:py-4 rounded-xl font-semibold text-lg transition-all text-center">
          See Features
        </a>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="relative z-10 pb-8 flex justify-center">
      <a href="#features" class="text-gray-400 hover:text-neon-cyan transition-colors animate-bounce">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </a>
    </div>
  </section>
  <!-- Features Section -->
  <section id="features" class="py-12 sm:py-16 md:py-24 px-4 sm:px-6 bg-gray-800/50 border-t border-neon-purple/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 font-display">
        <span class="text-neon-pink">Everything</span> <span class="text-neon-cyan">you need</span>
      </h2>
      <p class="text-gray-400 text-center mb-8 sm:mb-12 md:mb-16 text-lg max-w-2xl mx-auto">
        A complete media platform running on your own hardware.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Feature: Music Library -->
        <div class="bg-gray-800/80 border border-neon-purple/15 rounded-2xl p-5 sm:p-8 hover:border-neon-pink/30 transition-colors group">
          <div class="w-14 h-14 bg-neon-pink/10 border border-neon-pink/20 rounded-xl flex items-center justify-center mb-5 group-hover:shadow-neon-pink transition-shadow">
            <svg class="w-7 h-7 text-neon-pink" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2 text-neon-pink">Music Library</h3>
          <p class="text-gray-400 leading-relaxed">Upload your collection or import from YouTube. Browse by artist, album, or track. Download as ZIP anytime.</p>
        </div>
        <!-- Feature: Playlists -->
        <div class="bg-gray-800/80 border border-neon-purple/15 rounded-2xl p-5 sm:p-8 hover:border-neon-cyan/30 transition-colors group">
          <div class="w-14 h-14 bg-neon-cyan/10 border border-neon-cyan/20 rounded-xl flex items-center justify-center mb-5 group-hover:shadow-neon-cyan transition-shadow">
            <svg class="w-7 h-7 text-neon-cyan" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2 text-neon-cyan">Playlists</h3>
          <p class="text-gray-400 leading-relaxed">Create, reorder, and share playlists. Build them manually or generate from albums with one click.</p>
        </div>
        <!-- Feature: Streaming -->
        <div class="bg-gray-800/80 border border-neon-purple/15 rounded-2xl p-5 sm:p-8 hover:border-neon-purple/30 transition-colors group">
          <div class="w-14 h-14 bg-neon-purple/10 border border-neon-purple/20 rounded-xl flex items-center justify-center mb-5 group-hover:shadow-neon-pink transition-shadow">
            <svg class="w-7 h-7 text-neon-purple" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2 text-neon-purple">Stream Anywhere</h3>
          <p class="text-gray-400 leading-relaxed">Full player with queue, shuffle, and repeat. Native media controls on desktop and mobile via MediaSession API.</p>
        </div>
        <!-- Feature: Live TV -->
        <div class="bg-gray-800/80 border border-neon-purple/15 rounded-2xl p-5 sm:p-8 hover:border-sunset-orange/30 transition-colors group">
          <div class="w-14 h-14 bg-sunset-orange/10 border border-sunset-orange/20 rounded-xl flex items-center justify-center mb-5 group-hover:shadow-[0_0_10px_rgba(255,107,53,0.3)] transition-shadow">
            <svg class="w-7 h-7 text-sunset-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2 text-sunset-orange">Live TV</h3>
          <p class="text-gray-400 leading-relaxed">Stream IPTV channels via HLS. Import M3U playlists, filter by category, country, or language, and favorite the channels you watch most.</p>
        </div>
        <!-- Feature: TV Guide & DVR -->
        <div class="bg-gray-800/80 border border-neon-purple/15 rounded-2xl p-5 sm:p-8 hover:border-neon-purple/30 transition-colors group">
          <div class="w-14 h-14 bg-neon-purple/10 border border-neon-purple/20 rounded-xl flex items-center justify-center mb-5 group-hover:shadow-neon-pink transition-shadow">
            <svg class="w-7 h-7 text-neon-purple" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2 text-neon-purple">TV Guide & DVR</h3>
          <p class="text-gray-400 leading-relaxed">Browse the electronic program guide with real-time progress indicators. Schedule recordings and download them as MP4.</p>
        </div>
        <!-- Feature: Podcasts -->
        <div class="bg-gray-800/80 border border-neon-purple/15 rounded-2xl p-5 sm:p-8 hover:border-laser-green/30 transition-colors group">
          <div class="w-14 h-14 bg-laser-green/10 border border-laser-green/20 rounded-xl flex items-center justify-center mb-5 group-hover:shadow-[0_0_10px_rgba(57,255,20,0.3)] transition-shadow">
            <svg class="w-7 h-7 text-laser-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2 text-laser-green">Podcasts</h3>
          <p class="text-gray-400 leading-relaxed">Subscribe to podcast feeds and stream episodes alongside your music. Episodes auto-refresh on schedule.</p>
        </div>
        <!-- Feature: Radio -->
        <%= link_to public_radio_stations_path, class: "bg-gray-800/80 border border-neon-purple/15 rounded-2xl p-5 sm:p-8 hover:border-sunset-orange/30 transition-colors group block" do %>
          <div class="w-14 h-14 bg-sunset-orange/10 border border-sunset-orange/20 rounded-xl flex items-center justify-center mb-5 group-hover:shadow-[0_0_10px_rgba(255,107,53,0.3)] transition-shadow">
            <svg class="w-7 h-7 text-sunset-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728m-9.9-2.829a5 5 0 010-7.07m7.072 0a5 5 0 010 7.07M13 12a1 1 0 11-2 0 1 1 0 012 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2 text-sunset-orange">Live Radio</h3>
          <p class="text-gray-400 leading-relaxed">Curated playlists streaming 24/7 via Icecast. Tune in to live stations or add any internet radio stream.</p>
        <% end %>
        <!-- Feature: Themes -->
        <div class="bg-gray-800/80 border border-neon-purple/15 rounded-2xl p-5 sm:p-8 hover:border-neon-pink/30 transition-colors group">
          <div class="w-14 h-14 bg-neon-pink/10 border border-neon-pink/20 rounded-xl flex items-center justify-center mb-5 group-hover:shadow-neon-pink transition-shadow">
            <svg class="w-7 h-7 text-neon-pink" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2 text-neon-pink">Themes</h3>
          <p class="text-gray-400 leading-relaxed">Four music-genre-inspired themes &mdash; Synthwave, Reggae, Punk, and Jazz. Swap the entire look with one click.</p>
        </div>
      </div>
    </div>
  </section>
  <!-- Mobile Apps Section -->
  <section class="py-12 sm:py-16 md:py-24 px-4 sm:px-6 border-t border-neon-purple/10 relative overflow-hidden">
    <div class="absolute inset-0 retro-grid opacity-15"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 50%, rgba(139, 92, 246, 0.08) 0%, transparent 60%);"></div>
    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 font-display">
        <span class="text-neon-cyan">Take it</span> <span class="text-neon-pink">everywhere</span>
      </h2>
      <p class="text-gray-400 text-lg mb-8 sm:mb-12 max-w-2xl mx-auto">
        Native iOS app available now. Android coming soon. Your music, your server &mdash; in your pocket.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 sm:gap-8">
        <!-- iOS Card -->
        <div class="group relative">
          <!-- Glow border -->
          <div class="absolute -inset-1 bg-gradient-to-r from-neon-cyan/30 to-neon-purple/30 rounded-3xl blur-xl opacity-50 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative bg-gray-900 border border-neon-cyan/20 group-hover:border-neon-cyan/40 rounded-3xl p-6 sm:p-8 transition-colors duration-300">
            <!-- Phone silhouette -->
            <div class="mx-auto w-32 h-56 bg-gray-800 rounded-[1.5rem] border-2 border-gray-700 relative mb-6 overflow-hidden">
              <!-- Dynamic Island -->
              <div class="absolute top-2 left-1/2 -translate-x-1/2 w-16 h-4 bg-gray-900 rounded-full"></div>
              <!-- Screen content area -->
              <div class="absolute inset-4 top-8 bottom-6 rounded-lg bg-gradient-to-b from-neon-cyan/5 to-neon-purple/5 flex items-center justify-center">
                <!-- Apple logo -->
                <svg class="w-10 h-10 text-neon-cyan/40" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                </svg>
              </div>
              <!-- Home indicator -->
              <div class="absolute bottom-2 left-1/2 -translate-x-1/2 w-12 h-1 bg-gray-600 rounded-full"></div>
            </div>
            <!-- Available Now pill -->
            <div class="inline-flex items-center gap-2 bg-neon-cyan/15 border border-neon-cyan/50 text-neon-cyan px-4 py-1.5 rounded-full text-sm font-semibold mb-3">
              <span class="inline-flex rounded-full h-2 w-2 bg-neon-cyan shadow-[0_0_6px_var(--color-neon-cyan)]"></span>
              Available Now
            </div>
            <h3 class="text-xl font-bold text-white mb-1">iOS</h3>
            <p class="text-gray-400 text-sm">Native SwiftUI app with offline sync</p>
            <!-- App Store link -->
            <a href="https://apps.apple.com/app/synthwaves-fm/id6760940326"
               target="_blank"
               rel="noopener noreferrer"
               class="inline-flex items-center gap-2 mt-4 bg-neon-cyan/10 hover:bg-neon-cyan/20 border border-neon-cyan/40 hover:border-neon-cyan/60 hover:shadow-neon-cyan text-neon-cyan px-5 py-2.5 rounded-xl text-sm font-semibold transition-all">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              Download on the App Store
            </a>
          </div>
        </div>
        <!-- Android Card -->
        <div class="group relative">
          <!-- Glow border -->
          <div class="absolute -inset-1 bg-gradient-to-r from-neon-pink/30 to-neon-purple/30 rounded-3xl blur-xl opacity-50 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative bg-gray-900 border border-neon-pink/20 group-hover:border-neon-pink/40 rounded-3xl p-6 sm:p-8 transition-colors duration-300">
            <!-- Phone silhouette -->
            <div class="mx-auto w-32 h-56 bg-gray-800 rounded-[1.5rem] border-2 border-gray-700 relative mb-6 overflow-hidden">
              <!-- Camera punch-hole -->
              <div class="absolute top-3 left-1/2 -translate-x-1/2 w-3 h-3 bg-gray-900 rounded-full"></div>
              <!-- Screen content area -->
              <div class="absolute inset-4 top-8 bottom-6 rounded-lg bg-gradient-to-b from-neon-pink/5 to-neon-purple/5 flex items-center justify-center">
                <!-- Google Play logo -->
                <svg class="w-10 h-10 text-neon-pink/40" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 010 1.38l-2.302 2.302L15.394 12l2.304-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302L5.864 2.658z"/>
                </svg>
              </div>
              <!-- Home indicator -->
              <div class="absolute bottom-2 left-1/2 -translate-x-1/2 w-12 h-1 bg-gray-600 rounded-full"></div>
            </div>
            <!-- Coming Soon pill -->
            <div class="inline-flex items-center gap-2 bg-neon-pink/10 border border-neon-pink/30 text-neon-pink px-4 py-1.5 rounded-full text-sm font-semibold mb-3">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neon-pink opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-neon-pink"></span>
              </span>
              Coming Soon
            </div>
            <h3 class="text-xl font-bold text-white mb-1">Android</h3>
            <p class="text-gray-400 text-sm">Material You design with background playback</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Subsonic Compatibility Section -->
  <section class="py-12 sm:py-16 md:py-24 px-4 sm:px-6 border-t border-neon-purple/10">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-gray-400 text-lg mb-8 sm:mb-12 max-w-2xl mx-auto">
        synthwaves.fm was built to stream music to any Subsonic-compatible CLI music player.
        <span class="text-neon-pink">DSub</span>,
        <span class="text-neon-cyan">play:Sub</span>,
        <span class="text-neon-purple">Ultrasonic</span>,
        and more.
      </p>
      <div class="grid grid-cols-3 gap-3 sm:gap-6 max-w-3xl mx-auto">
        <div class="bg-gray-800/60 border border-neon-purple/15 rounded-xl p-3 sm:p-6">
          <div class="text-xl sm:text-3xl font-display text-neon-pink mb-1 sm:mb-2">22</div>
          <div class="text-gray-400 text-xs sm:text-sm">API endpoints</div>
        </div>
        <div class="bg-gray-800/60 border border-neon-purple/15 rounded-xl p-3 sm:p-6">
          <div class="text-xl sm:text-3xl font-display text-neon-cyan mb-1 sm:mb-2">REST</div>
          <div class="text-gray-400 text-xs sm:text-sm">JSON &amp; XML API</div>
        </div>
        <div class="bg-gray-800/60 border border-neon-purple/15 rounded-xl p-3 sm:p-6">
          <div class="text-xl sm:text-3xl font-display text-neon-purple mb-1 sm:mb-2">JWT</div>
          <div class="text-gray-400 text-xs sm:text-sm">Token auth</div>
        </div>
      </div>
    </div>
  </section>
  <!-- Tech Stack Section -->
  <section class="py-12 sm:py-16 md:py-24 px-4 sm:px-6 bg-gray-800/30 border-t border-neon-purple/10">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 font-display">
        <span class="text-neon-cyan">Built with</span> <span class="text-neon-pink">Rails 8</span>
      </h2>
      <p class="text-gray-400 text-lg mb-8 sm:mb-12 max-w-2xl mx-auto">
        Modern stack, zero complexity. SQLite for everything, Hotwire for interactivity, Solid Queue for background jobs.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <% %w[Ruby\ on\ Rails Hotwire SQLite Tailwind\ CSS Stimulus Turbo Solid\ Queue Solid\ Cache Importmap ViewComponent].each do |tech| %>
          <span class="bg-gray-800/80 border border-neon-purple/20 text-gray-400 px-4 py-2 rounded-full text-sm font-medium hover:text-neon-cyan hover:border-neon-cyan/30 transition-colors cursor-default">
            <%= tech %>
          </span>
        <% end %>
      </div>
    </div>
  </section>
  <!-- Final CTA Section -->
  <section class="py-12 sm:py-16 md:py-24 px-4 sm:px-6 border-t border-neon-purple/10 relative overflow-hidden">
    <div class="absolute inset-0 retro-grid opacity-20"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 50%, rgba(255, 45, 149, 0.08) 0%, transparent 60%);"></div>
    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 font-display text-sunset">
        Ready to groove?
      </h2>
      <p class="text-gray-400 text-lg mb-10">
        Set up your server, add your media, and start streaming in minutes.
      </p>
      <% if Flipper.enabled?(:open_registration) %>
        <%= render Button::Component.new(label: "Get Started Free", behavior: :navigation, link_url: new_registration_path, style: :gradient, extra_classes: "shadow-lg") %>
      <% end %>
    </div>
  </section>
  <!-- Footer -->
  <footer class="py-6 px-4 sm:py-10 sm:px-6 bg-gray-800/50 border-t border-neon-purple/20">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-2">
        <%= render(Logo::Component.new(size: :sm, icon: true)) %>
        <span class="text-gray-400 text-sm">&copy; <%= Date.current.year %> synthwaves.fm</span>
      </div>
      <div class="flex items-center gap-4">
        <%= link_to "Radio", public_radio_stations_path, class: "text-gray-400 hover:text-neon-cyan text-sm transition-colors" %>
        <%= link_to "Privacy", privacy_path, class: "text-gray-400 hover:text-neon-cyan text-sm transition-colors" %>
        <a href="https://github.com/leopolicastro/synthwaves.fm" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-neon-cyan text-sm transition-colors">GitHub</a>
      </div>
    </div>
  </footer>
