<div class="w-full max-w-lg">
  <h1 class="text-3xl font-bold font-display mb-6">Upload Season</h1>

  <%= form_with url: folders_path, method: :post, multipart: true, class: "space-y-4",
                data: { controller: "bulk-upload" } do |f| %>
    <% if @folder.errors.any? %>
      <div class="bg-red-900/20 border border-red-800 rounded-lg p-4">
        <ul class="text-sm text-red-400">
          <% @folder.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-medium text-gray-400 mb-1">Folder Name</label>
      <input type="text" name="folder_name" value="<%= params[:folder_name] %>" required
             list="existing-folders"
             placeholder="e.g. Breaking Bad"
             class="w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan px-3 py-2 text-sm border">
      <datalist id="existing-folders">
        <% @existing_folders.each do |folder| %>
          <option value="<%= folder.name %>">
        <% end %>
      </datalist>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-400 mb-1">Season Number <span class="text-gray-500">(optional)</span></label>
      <input type="number" name="season_number" value="<%= params[:season_number] %>" min="1"
             placeholder="e.g. 1"
             class="w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan px-3 py-2 text-sm border">
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-400 mb-1">Video Files</label>
      <input type="file" name="video_files[]" accept="video/*,.mkv" multiple required
             data-bulk-upload-target="input"
             data-action="change->bulk-upload#filesChanged"
             class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-neon-cyan/10 file:text-neon-cyan hover:file:bg-neon-cyan/20">
      <p class="mt-1 text-sm text-gray-500">Select multiple video files. Episode numbers will be parsed from filenames (e.g. S01E03, E03, 03 - Title).</p>
    </div>

    <div data-bulk-upload-target="preview" class="hidden">
      <label class="block text-sm font-medium text-gray-400 mb-2">Selected Files</label>
      <ul data-bulk-upload-target="list" class="space-y-1 text-sm text-gray-400 bg-gray-800/50 rounded-lg border border-gray-700 p-3 max-h-48 overflow-y-auto">
      </ul>
    </div>

    <div>
      <%= f.submit "Upload Season", class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink cursor-pointer" %>
    </div>
  <% end %>
</div>
