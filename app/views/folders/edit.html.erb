<div class="w-full max-w-lg">
  <h1 class="text-3xl font-bold font-display mb-6">Edit Folder</h1>

  <%= form_with model: @folder, class: "space-y-4" do |f| %>
    <% if @folder.errors.any? %>
      <div class="bg-red-900/20 border border-red-800 rounded-lg p-4">
        <ul class="text-sm text-red-400">
          <% @folder.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.text_field :name, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan px-3 py-2 text-sm border" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.text_area :description, rows: 3, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan px-3 py-2 text-sm border" %>
    </div>

    <div>
      <%= f.label :cover_image, "Cover Image", class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.file_field :cover_image, accept: "image/*",
            class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-neon-cyan/10 file:text-neon-cyan hover:file:bg-neon-cyan/20" %>
    </div>

    <div>
      <%= f.submit "Save", class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink cursor-pointer" %>
      <%= link_to "Cancel", folder_path(@folder), class: "px-4 py-2 text-gray-400 hover:text-neon-cyan" %>
    </div>
  <% end %>
</div>
