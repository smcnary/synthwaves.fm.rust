<div class="w-full">
  <h1 class="text-3xl font-bold font-display mb-6">Recordings</h1>

  <%= turbo_stream_from "recordings_#{Current.user.id}" %>

  <div data-controller="search" class="mb-6">
    <%= form_with url: recordings_path, method: :get, data: { turbo_frame: "recordings-list", search_target: "form", action: "input->search#submit" } do |f| %>
      <div class="flex flex-col sm:flex-row gap-3">
        <input type="text" name="q" value="<%= @query %>" placeholder="Search recordings..."
               class="flex-1 rounded-lg bg-gray-800 border-gray-700 text-white text-lg px-4 py-3 focus:outline-neon-cyan"
               data-search-target="input" autofocus>

        <div class="flex items-center gap-3">
          <label for="status" class="text-sm text-gray-500">Status</label>
          <select name="status" id="status" data-action="change->search#submit" class="text-sm rounded-md border-gray-600 bg-gray-700 text-white">
            <option value="">All</option>
            <% Recording::STATUSES.each do |s| %>
              <option value="<%= s %>" <%= "selected" if s == @status %>><%= s.capitalize %></option>
            <% end %>
          </select>

          <label for="sort" class="text-sm text-gray-500">Sort by</label>
          <select name="sort" id="sort" data-action="change->search#submit" class="text-sm rounded-md border-gray-600 bg-gray-700 text-white">
            <% Recording::SORT_OPTIONS.each do |value, label| %>
              <option value="<%= value %>" <%= "selected" if value == @sort %>><%= label %></option>
            <% end %>
          </select>

          <select name="direction" id="direction" data-action="change->search#submit" class="text-sm rounded-md border-gray-600 bg-gray-700 text-white">
            <option value="asc" <%= "selected" if @direction == "asc" %>>Ascending</option>
            <option value="desc" <%= "selected" if @direction == "desc" %>>Descending</option>
          </select>
        </div>
      </div>
    <% end %>
  </div>

  <turbo-frame id="recordings-list" data-turbo-action="replace">
    <% if @recordings.any? %>
      <div class="space-y-3">
        <% @recordings.each do |recording| %>
          <%= render "recordings/recording", recording: recording %>
        <% end %>
      </div>

      <div class="mt-6 flex justify-center">
        <%== @pagy.series_nav %>
      </div>
    <% else %>
      <p class="text-gray-500">No recordings found<%= " for \"#{@query}\"" if @query.present? %>.</p>
    <% end %>
  </turbo-frame>
</div>
