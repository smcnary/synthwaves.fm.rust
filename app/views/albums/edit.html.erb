<div class="w-full max-w-lg">
  <h1 class="text-3xl font-bold font-display mb-6">Edit Album</h1>

  <%= form_with model: @album, class: "space-y-4" do |f| %>
    <% if @album.errors.any? %>
      <div class="bg-red-900/20 border border-red-800 rounded-lg p-4">
        <ul class="text-sm text-red-400">
          <% @album.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.text_field :title, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan" %>
    </div>

    <div>
      <%= f.label :artist_id, "Artist", class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.collection_select :artist_id, @artists, :id, :name, {}, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan" %>
    </div>

    <div>
      <%= f.label :year, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.number_field :year, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan" %>
    </div>

    <div>
      <%= f.label :genre, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.text_field :genre, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan" %>
    </div>

    <div>
      <%= f.submit "Save", class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink cursor-pointer" %>
      <%= link_to "Cancel", album_path(@album), class: "px-4 py-2 text-gray-400 hover:text-neon-cyan" %>
    </div>
  <% end %>
</div>
