<div class="w-full">
  <div class="mb-6">
    <%= link_to "&larr; Albums".html_safe, albums_path, class: "text-blue-600 hover:underline" %>
  </div>

  <div class="flex items-start gap-6 mb-8">
    <% if @album.cover_image.attached? %>
      <%= image_tag @album.cover_image, class: "w-48 h-48 rounded-lg object-cover shadow-lg" %>
    <% else %>
      <div class="w-48 h-48 rounded-lg bg-gray-200 dark:bg-gray-700 flex items-center justify-center shadow-lg">
        <svg class="w-16 h-16 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"/></svg>
      </div>
    <% end %>
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white"><%= @album.title %></h1>
      <p class="text-lg text-gray-600 dark:text-gray-400"><%= link_to @album.artist.name, artist_path(@album.artist), class: "hover:underline" %></p>
      <% if @album.year %><p class="text-gray-500"><%= @album.year %></p><% end %>
      <% if @album.genre %><p class="text-gray-500"><%= @album.genre %></p><% end %>
      <p class="text-sm text-gray-400 mt-2"><%= pluralize(@tracks.size, "track") %></p>

      <div class="mt-3">
        <%= render BulkPlaylistMenuComponent.new(
              tracks: @tracks,
              playlists: current_user_playlists,
              new_playlist_name: @album.title
            ) %>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
    <% @tracks.each do |track| %>
      <%= render TrackRowComponent.new(track: track, number: track.track_number, show_album: false, hide_artist_if: @album.artist) do |c| %>
        <% c.with_trailing do %>
          <%= render "playlist_tracks/add_menu", track: track, playlists: current_user_playlists %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
