<% content_for :meta_title, "#{@album.title} by #{@album.artist.name} — synthwaves.fm" %>
<% content_for :meta_description, "#{@album.artist.name} · #{@album.year} · #{@album.genre} · #{pluralize(@total_tracks, 'track')}" %>
<% if @album.cover_image.attached? %>
  <% content_for :meta_image, og_image_url_for(@album.cover_image) %>
<% end %>
<% content_for :meta_type, "music.album" %>

<div class="w-full">
  <div class="mb-6">
    <%= link_to "&larr; Albums".html_safe, albums_path, class: "text-neon-cyan hover:underline" %>
  </div>
  <div class="flex flex-col sm:flex-row items-start gap-4 sm:gap-6 mb-8">
    <% if @album.cover_image.attached? %>
      <%= image_tag @album.cover_image, class: "w-32 h-32 sm:w-48 sm:h-48 rounded-lg object-cover shadow-lg" %>
    <% else %>
      <div class="w-32 h-32 sm:w-48 sm:h-48 rounded-lg bg-gray-700 flex items-center justify-center shadow-lg">
        <svg class="w-16 h-16 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"/></svg>
      </div>
    <% end %>
    <div>
      <h1 class="text-3xl font-bold font-display text-white"><%= @album.title %></h1>
      <p class="text-lg text-gray-400"><%= link_to @album.artist.name, artist_path(@album.artist), class: "hover:underline" %></p>
      <% if @album.year %>
        <p class="text-gray-500"><%= @album.year %></p>
      <% end %>
      <% if @album.genre %>
        <p class="text-gray-500"><%= @album.genre %></p>
      <% end %>
      <p class="text-sm text-gray-400 mt-2"><%= pluralize(@total_tracks, "track") %></p>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <%= render "favorites/button", favorable: @album, favorited: Current.user.favorites.exists?(favorable: @album) %>
        <%= render BulkPlaylistMenuComponent.new(
              tracks: @all_tracks,
              playlists: current_user_playlists,
              new_playlist_name: @album.title
            ) %>
        <%= button_to "Export ZIP", downloads_path(downloadable_type: "Album", downloadable_id: @album.id), class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-neon-cyan bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors" %>
        <%= button_to "Fetch cover", fetch_cover_album_path(@album), class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-neon-cyan bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors" %>
        <% if @album.youtube_playlist_url.present? %>
          <%= button_to "Refresh Episodes", refresh_album_path(@album), class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-neon-cyan bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors" %>
        <% end %>
        <% if @album.tracks.where.not(youtube_video_id: [nil, ""]).where.missing(:audio_file_attachment).any? %>
          <%= button_to "Download Audio", download_audio_album_path(@album), class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-neon-cyan bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors" %>
        <% end %>
        <% if Current.user.admin? %>
          <%= link_to "Edit", edit_album_path(@album), class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-neon-cyan bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors" %>
          <%= button_to "Delete", album_path(@album), method: :delete, class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-red-400 bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors", data: { turbo_confirm: "Delete \"#{@album.title}\" and all its tracks? This cannot be undone." } %>
          <%= render "albums/merge_menu", album: @album %>
        <% end %>
      </div>
      <% if Flipper.enabled?(:youtube_import, Current.user) %>
        <%= form_with model: @album, class: "mt-3 flex flex-col sm:flex-row items-stretch sm:items-center gap-2" do |f| %>
          <%= f.text_field :youtube_playlist_url,
                placeholder: "YouTube playlist URL",
                class: "text-sm rounded-lg border border-gray-600 bg-gray-700 text-white px-3 py-2 flex-1 min-w-0 focus:outline-neon-cyan" %>
          <%= f.submit "Save",
                class: "px-3 py-1 text-sm font-medium text-white bg-neon-pink hover:shadow-neon-pink rounded-md cursor-pointer" %>
        <% end %>
      <% end %>
    </div>
  </div>
  <turbo-frame id="album-tracks" data-turbo-action="advance">
    <form action="<%= album_path(@album) %>" method="get" data-controller="search" data-search-target="form" class="mb-4 flex items-center gap-3">
      <label for="sort" class="text-sm text-gray-400 font-medium">Sort by</label>
      <select name="sort" id="sort" data-action="change->search#submit" class="text-sm rounded-lg border border-gray-600 bg-gray-700 text-white px-3 py-2 focus:outline-neon-cyan">
        <% Track::ALBUM_SORT_OPTIONS.each do |value, label| %>
          <option value="<%= value %>" <%= "selected" if value == @sort %>><%= label %></option>
          <% end %>
        </select>
        <select name="direction" id="direction" data-action="change->search#submit" class="text-sm rounded-lg border border-gray-600 bg-gray-700 text-white px-3 py-2 focus:outline-neon-cyan">
          <option value="asc" <%= "selected" if @direction == "asc" %>>Ascending</option>
        <option value="desc" <%= "selected" if @direction == "desc" %>>Descending</option>
      </select>
    </form>

    <div class="bg-gray-800 rounded-lg border border-gray-700">
      <% @tracks.each do |track| %>
        <%= render TrackRowComponent.new(track: track, number: (@sort == "disc_number" ? track.track_number : nil), link_title: true, link_subtitle: true, show_album: false, hide_artist_if: @album.artist) do |c| %>
          <% c.with_trailing do %>
            <% if track.audio_file.attached? %>
              <%= link_to download_track_path(track), class: "text-gray-400 hover:text-neon-cyan", title: "Download" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              <% end %>
            <% end %>
            <%= render "favorites/button", favorable: track, favorited: @favorited_track_ids.include?(track.id) %>
            <%= render "playlist_tracks/add_menu", track: track, playlists: current_user_playlists %>
          <% end %>
        <% end %>
      <% end %>
    </div>
            <% if @pagy.pages > 1 %>
              <div class="mt-6 flex justify-center">
                <%== @pagy.series_nav %>
              </div>
            <% end %>
          </turbo-frame>
        </div>
