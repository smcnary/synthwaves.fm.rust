<div class="w-full">
  <div class="mb-6">
    <%= link_to "&larr; Albums".html_safe, albums_path, class: "text-blue-600 hover:underline" %>
  </div>

  <div class="flex items-start gap-6 mb-8">
    <% if @album.cover_image.attached? %>
      <%= image_tag @album.cover_image, class: "w-48 h-48 rounded-lg object-cover shadow-lg" %>
    <% else %>
      <div class="w-48 h-48 rounded-lg bg-gray-200 dark:bg-gray-700 flex items-center justify-center shadow-lg">
        <svg class="w-16 h-16 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"/></svg>
      </div>
    <% end %>
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white"><%= @album.title %></h1>
      <p class="text-lg text-gray-600 dark:text-gray-400"><%= link_to @album.artist.name, artist_path(@album.artist), class: "hover:underline" %></p>
      <% if @album.year %><p class="text-gray-500"><%= @album.year %></p><% end %>
      <% if @album.genre %><p class="text-gray-500"><%= @album.genre %></p><% end %>
      <p class="text-sm text-gray-400 mt-2"><%= pluralize(@total_tracks, "track") %></p>

      <div class="mt-3">
        <%= render BulkPlaylistMenuComponent.new(
              tracks: @all_tracks,
              playlists: current_user_playlists,
              new_playlist_name: @album.title
            ) %>
      </div>
    </div>
  </div>

  <turbo-frame id="album-tracks" data-turbo-action="advance">
    <form action="<%= album_path(@album) %>" method="get" data-controller="search" data-search-target="form" class="mb-4 flex items-center gap-3">
      <label for="sort" class="text-sm text-gray-500 dark:text-gray-400">Sort by</label>
      <select name="sort" id="sort" data-action="change->search#submit" class="text-sm rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white">
        <% Track::ALBUM_SORT_OPTIONS.each do |value, label| %>
          <option value="<%= value %>" <%= "selected" if value == @sort %>><%= label %></option>
        <% end %>
      </select>

      <select name="direction" id="direction" data-action="change->search#submit" class="text-sm rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white">
        <option value="asc" <%= "selected" if @direction == "asc" %>>Ascending</option>
        <option value="desc" <%= "selected" if @direction == "desc" %>>Descending</option>
      </select>
    </form>

    <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
      <% @tracks.each do |track| %>
        <%= render TrackRowComponent.new(track: track, number: (@sort == "disc_number" ? track.track_number : nil), show_album: false, hide_artist_if: @album.artist) do |c| %>
          <% c.with_trailing do %>
            <%= render "playlist_tracks/add_menu", track: track, playlists: current_user_playlists %>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="mt-6 flex justify-center">
        <%== @pagy.series_nav %>
      </div>
    <% end %>
  </turbo-frame>
</div>
