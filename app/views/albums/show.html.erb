<div class="w-full">
  <div class="mb-6">
    <%= link_to "&larr; Albums".html_safe, albums_path, class: "text-blue-600 hover:underline" %>
  </div>

  <div class="flex items-start gap-6 mb-8">
    <% if @album.cover_image.attached? %>
      <%= image_tag @album.cover_image, class: "w-48 h-48 rounded-lg object-cover shadow-lg" %>
    <% else %>
      <div class="w-48 h-48 rounded-lg bg-gray-200 dark:bg-gray-700 flex items-center justify-center shadow-lg">
        <svg class="w-16 h-16 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"/></svg>
      </div>
    <% end %>
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white"><%= @album.title %></h1>
      <p class="text-lg text-gray-600 dark:text-gray-400"><%= link_to @album.artist.name, artist_path(@album.artist), class: "hover:underline" %></p>
      <% if @album.year %><p class="text-gray-500"><%= @album.year %></p><% end %>
      <% if @album.genre %><p class="text-gray-500"><%= @album.genre %></p><% end %>
      <p class="text-sm text-gray-400 mt-2"><%= pluralize(@tracks.size, "track") %></p>

      <div class="relative mt-3" data-controller="playlist-menu" data-action="click@window->playlist-menu#close">
        <button data-action="click->playlist-menu#toggle" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add to Playlist
        </button>
        <div data-playlist-menu-target="menu" class="hidden absolute left-0 z-10 mt-1 w-56 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg">
          <%= button_to "New Playlist", create_playlist_album_path(@album),
                method: :post,
                class: "block w-full text-left px-4 py-2 text-sm font-medium text-blue-600 dark:text-blue-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-t-lg" %>
          <% if current_user_playlists.any? %>
            <div class="border-t border-gray-200 dark:border-gray-700"></div>
            <% current_user_playlists.each do |playlist| %>
              <%= button_to playlist_tracks_path(playlist),
                    params: { album_id: @album.id },
                    method: :post,
                    class: "block w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 last:rounded-b-lg" do %>
                <%= playlist.name %>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
    <% @tracks.each do |track| %>
      <%= render TrackRowComponent.new(track: track, number: track.track_number, show_album: false, hide_artist_if: @album.artist) do |c| %>
        <% c.with_trailing do %>
          <%= render "playlist_tracks/add_menu", track: track, playlists: current_user_playlists %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
