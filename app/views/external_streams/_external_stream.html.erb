<div class="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden group collection-card-inner">
  <div class="relative aspect-video bg-gray-700 collection-card-image">
    <% if station.thumbnail_url.present? %>
      <img src="<%= station.thumbnail_url %>" alt="<%= station.name %>" class="w-full h-full object-cover">
    <% else %>
      <div class="w-full h-full flex items-center justify-center">
        <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728M9.172 14.828a4 4 0 010-5.656m5.656 0a4 4 0 010 5.656M12 12h.01"/>
        </svg>
      </div>
    <% end %>
    <!-- Play button overlay -->
    <button type="button"
            class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/30 transition-colors"
            data-controller="song-row"
            data-song-row-track-id-value="0"
            data-song-row-title-value="<%= station.name %>"
            data-song-row-artist-value="Live"
            <% if station.youtube? %>
              data-song-row-youtube-video-id-value="<%= station.youtube_video_id %>"
            <% else %>
              data-song-row-stream-url-value="<%= station.needs_proxy? ? external_stream_stream_path(station) : station.stream_url %>"
            <% end %>
            data-song-row-is-live-value="true"
            data-action="song-row#play">
      <div class="w-14 h-14 rounded-full bg-neon-pink text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity shadow-lg">
        <svg class="w-7 h-7 ml-1" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/></svg>
      </div>
    </button>
  </div>
  <div class="p-4 collection-card-body">
    <div class="flex items-start justify-between gap-2">
      <div class="min-w-0">
        <h3 class="font-medium text-white truncate"><%= station.name %></h3>
        <% if station.youtube? %>
          <span class="inline-flex items-center gap-1 mt-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-900 text-red-300">
            <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
            LIVE
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1 mt-1 px-2 py-0.5 rounded-full text-xs font-medium bg-cyan-900 text-cyan-300">
            <span class="w-1.5 h-1.5 rounded-full bg-cyan-500 animate-pulse"></span>
            RADIO
          </span>
        <% end %>
      </div>
      <% if authenticated? && Current.user == station.user %>
        <%= button_to external_stream_path(station), method: :delete, data: { turbo_confirm: "Remove this station?" }, class: "text-gray-400 hover:text-red-500 flex-shrink-0" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
