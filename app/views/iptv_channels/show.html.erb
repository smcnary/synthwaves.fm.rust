<div class="w-full" data-controller="hls-player tv-page"
     data-hls-player-autoplay-url-value="<%= @channel.stream_url %>"
     data-hls-player-autoplay-name-value="<%= @channel.name %>">
  <div class="mb-6">
    <%= link_to tv_path, class: "text-sm text-gray-400 hover:text-neon-cyan transition-colors" do %>
      &larr; Back to TV
    <% end %>
  </div>

  <%# Video player %>
  <div class="mb-6 relative bg-black rounded-xl overflow-hidden aspect-video max-w-4xl mx-auto">
    <video data-hls-player-target="video"
           class="w-full h-full"
           controls
           playsinline></video>
    <div data-hls-player-target="loading"
         class="absolute inset-0 flex items-center justify-center bg-black/50">
      <div class="w-8 h-8 border-2 border-neon-cyan border-t-transparent rounded-full animate-spin"></div>
    </div>
    <div data-hls-player-target="error"
         class="absolute inset-0 flex items-center justify-center bg-black/80 text-red-400 text-sm px-4 text-center hidden">
    </div>
  </div>

  <%# Channel info %>
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-4 mb-4">
      <% if @channel.logo_url.present? %>
        <div class="w-14 h-14 rounded-lg bg-gray-800 overflow-hidden flex-shrink-0">
          <img src="<%= @channel.logo_url %>" alt="<%= @channel.name %>" class="w-full h-full object-contain">
        </div>
      <% end %>
      <div>
        <h1 class="text-2xl font-bold font-display"><%= @channel.name %></h1>
        <div class="flex items-center gap-3 text-sm text-gray-400 mt-1">
          <% if @channel.iptv_category.present? %>
            <%= link_to @channel.iptv_category.name, tv_path(tab: "guide", category: @channel.iptv_category.slug),
                  class: "hover:text-neon-cyan transition-colors" %>
          <% end %>
          <% if @channel.country.present? %>
            <span><%= @channel.country %></span>
          <% end %>
          <% if @channel.language.present? %>
            <span><%= @channel.language %></span>
          <% end %>
        </div>
      </div>
      <div class="ml-auto flex items-center gap-3">
        <%= render "favorites/button", favorable: @channel, favorited: @is_favorited %>
        <%= link_to "Edit", edit_iptv_channel_path(@channel), class: "px-3 py-1.5 text-sm border border-gray-600 text-gray-300 rounded-lg hover:border-neon-cyan hover:text-neon-cyan transition-colors" %>
        <%= button_to "Delete", iptv_channel_path(@channel), method: :delete, class: "px-3 py-1.5 text-sm border border-gray-600 text-red-400 rounded-lg hover:border-red-400 transition-colors cursor-pointer", data: { turbo_confirm: "Remove this channel?" } %>
      </div>
    </div>

    <%# Now Playing %>
    <% if @now_playing %>
      <div class="mt-6 p-4 rounded-xl border border-neon-cyan/20 bg-gray-800/60">
        <div class="flex items-center gap-2 mb-2">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500"></span>
          </span>
          <span class="text-xs font-medium text-red-400 uppercase tracking-wide">Now Playing</span>
        </div>
        <div class="flex items-start justify-between gap-2">
          <h3 class="text-lg font-semibold text-white"><%= @now_playing.title %></h3>
          <div class="flex-shrink-0">
            <%= render "recordings/record_button", channel: @channel, programme: @now_playing, status: @recording_by_programme_id[@now_playing.id] %>
          </div>
        </div>
        <% if @now_playing.subtitle.present? %>
          <p class="text-sm text-gray-300 mt-0.5"><%= @now_playing.subtitle %></p>
        <% end %>
        <% if @now_playing.description.present? %>
          <p class="text-sm text-gray-400 mt-2 line-clamp-3"><%= @now_playing.description %></p>
        <% end %>
        <div class="mt-3">
          <div class="flex items-center justify-between text-xs text-gray-400 mb-1">
            <span><%= @now_playing.starts_at.strftime("%-I:%M %p") %></span>
            <span><%= @now_playing.remaining_minutes %> min remaining</span>
            <span><%= @now_playing.ends_at.strftime("%-I:%M %p") %></span>
          </div>
          <div class="h-1.5 bg-gray-700 rounded-full overflow-hidden">
            <div class="h-full bg-neon-cyan rounded-full transition-all" style="width: <%= @now_playing.progress_percentage %>%"></div>
          </div>
        </div>
      </div>
    <% end %>

    <%# Up Next %>
    <% if @up_next.any? %>
      <div class="mt-4">
        <h3 class="text-sm font-medium text-gray-400 uppercase tracking-wide mb-2">Up Next</h3>
        <div class="space-y-1">
          <% @up_next.each do |programme| %>
            <div class="flex items-center gap-3 p-2.5 rounded-lg bg-gray-800/40 border border-gray-700/30 group">
              <span class="text-xs text-gray-500 w-16 flex-shrink-0"><%= programme.starts_at.strftime("%-I:%M %p") %></span>
              <div class="min-w-0 flex-1">
                <span class="text-sm text-white truncate block"><%= programme.title %></span>
                <% if programme.subtitle.present? %>
                  <span class="text-xs text-gray-400 truncate block"><%= programme.subtitle %></span>
                <% end %>
              </div>
              <% rec_status = @recording_by_programme_id[programme.id] %>
              <% if rec_status %>
                <div class="flex-shrink-0">
                  <%= render "recordings/record_button", channel: @channel, programme: programme, status: rec_status, size: :small %>
                </div>
              <% else %>
                <div class="flex-shrink-0 opacity-0 group-hover:opacity-100 transition-all">
                  <%= render "recordings/record_button", channel: @channel, programme: programme, size: :small %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
