<%= form_with model: @channel, url: url, class: "space-y-6 max-w-lg" do |f| %>
  <% if @channel.errors.any? %>
    <div class="bg-red-900/50 border border-red-500 rounded-lg p-4">
      <% @channel.errors.full_messages.each do |msg| %>
        <p class="text-sm text-red-300"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-400 mb-1" %>
    <%= f.text_field :name, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan focus:border-transparent", required: true %>
  </div>

  <div>
    <%= f.label :stream_url, "Stream URL", class: "block text-sm font-medium text-gray-400 mb-1" %>
    <%= f.url_field :stream_url, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan focus:border-transparent", placeholder: "https://example.com/stream.m3u8", required: true %>
  </div>

  <div>
    <%= f.label :logo_url, "Logo URL", class: "block text-sm font-medium text-gray-400 mb-1" %>
    <%= f.url_field :logo_url, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan focus:border-transparent", placeholder: "https://example.com/logo.png" %>
  </div>

  <div>
    <%= f.label :epg_url, "EPG URL", class: "block text-sm font-medium text-gray-400 mb-1" %>
    <%= f.url_field :epg_url, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan focus:border-transparent", placeholder: "https://epg.pw/xmltv/epg_US.xml" %>
    <p class="text-xs text-gray-500 mt-1">Optional XMLTV EPG source. Channels sharing the same URL are fetched together.</p>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :country, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.text_field :country, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan focus:border-transparent", placeholder: "US" %>
    </div>
    <div>
      <%= f.label :language, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.text_field :language, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan focus:border-transparent", placeholder: "English" %>
    </div>
  </div>

  <div>
    <%= f.label :iptv_category_id, "Category", class: "block text-sm font-medium text-gray-400 mb-1" %>
    <%= f.collection_select :iptv_category_id, @categories, :id, :name, { include_blank: "None" }, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan" %>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink text-sm font-medium cursor-pointer" %>
    <%= link_to "Cancel", (@channel.persisted? ? iptv_channel_path(@channel) : tv_path), class: "text-sm text-gray-400 hover:text-white" %>
  </div>
<% end %>
