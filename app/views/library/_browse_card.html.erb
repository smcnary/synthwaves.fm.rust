<%= link_to path, class: "bg-gray-800 rounded-lg border border-gray-700 p-4 hover:border-neon-purple/40 hover:shadow-lg transition-all flex items-center gap-3" do %>
  <div class="w-10 h-10 rounded-lg bg-<%= color %>-900 flex items-center justify-center">
    <%= icon %>
  </div>
  <div>
    <div class="font-medium text-white"><%= label %></div>
    <div class="text-sm text-gray-500"><%= pluralize(count, item_name) %></div>
  </div>
<% end %>
