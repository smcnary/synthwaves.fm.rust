<%= link_to podcast_path(podcast), class: "group w-40 flex-shrink-0" do %>
  <div class="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden hover:border-neon-purple/40 hover:shadow-lg transition-all">
    <% last_album = podcast.albums.max_by(&:created_at) %>
    <% if last_album&.cover_image&.attached? %>
      <%= image_tag last_album.cover_image, class: "w-full aspect-square object-cover", loading: "lazy" %>
    <% else %>
      <div class="w-full aspect-square bg-gray-700 flex items-center justify-center">
        <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
        </svg>
      </div>
    <% end %>
    <div class="p-2">
      <div class="font-medium text-sm text-white group-hover:text-neon-cyan truncate"><%= podcast.name %></div>
      <div class="text-xs text-gray-500"><%= pluralize(podcast.tracks.count, "episode") %></div>
    </div>
  </div>
<% end %>
