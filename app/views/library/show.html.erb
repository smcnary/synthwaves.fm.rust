<div class="w-full">
  <h1 class="text-3xl font-bold mb-8">Library</h1>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
      <div class="text-3xl font-bold text-blue-600"><%= @artist_count %></div>
      <div class="text-gray-500 dark:text-gray-400">Artists</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
      <div class="text-3xl font-bold text-green-600"><%= @album_count %></div>
      <div class="text-gray-500 dark:text-gray-400">Albums</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
      <div class="text-3xl font-bold text-purple-600"><%= @track_count %></div>
      <div class="text-gray-500 dark:text-gray-400">Tracks</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
      <div class="text-3xl font-bold text-orange-600"><%= format_duration(@total_duration || 0) %></div>
      <div class="text-gray-500 dark:text-gray-400">Total Duration</div>
    </div>
  </div>

  <div class="flex gap-4 mb-8">
    <%= link_to "Upload Track", new_track_path, class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700" %>
    <% if Flipper.enabled?(:youtube_import, Current.user) %>
      <%= link_to "Import from YouTube", new_youtube_import_path, class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700" %>
    <% end %>
    <%= link_to "Browse Artists", artists_path, class: "px-4 py-2 bg-gray-200 dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600" %>
    <%= link_to "Browse Albums", albums_path, class: "px-4 py-2 bg-gray-200 dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600" %>
  </div>

  <% if @recent_tracks.any? %>
    <h2 class="text-xl font-semibold mb-4">Recently Added</h2>
    <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
      <% @recent_tracks.each do |track| %>
        <%= render TrackRowComponent.new(track: track, link_subtitle: true) do |c| %>
          <% c.with_trailing do %>
            <%= render "playlist_tracks/add_menu", track: track, playlists: current_user_playlists %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
