<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Groovy Tunes" %></title>

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Groovy Tunes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen">
    <%= yield %>
  </body>

  <%# Footer %>
  <footer class="bg-gray-100 dark:bg-gray-800 py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-600 dark:text-gray-400 text-sm">
          &copy; <%= Date.current.year %> Boilercode. All rights reserved.
        </p>
        <div class="flex gap-6">
          <%= link_to "Privacy", "#", class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
          <%= link_to "Terms", "#", class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
          <%= link_to "GitHub", "https://github.com", target: "_blank", rel: "noopener", class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
        </div>
      </div>
    </div>
  </footer>
</html>
