<div class="w-full max-w-lg">
  <h1 class="text-3xl font-bold font-display mb-6">Upload Video</h1>

  <%= form_with url: videos_path, method: :post, multipart: true, class: "space-y-4" do |f| %>
    <% if @video.errors.any? %>
      <div class="bg-red-900/20 border border-red-800 rounded-lg p-4">
        <ul class="text-sm text-red-400">
          <% @video.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Video File</label>
      <input type="file" name="video_file" accept="video/*,.mkv" required
             class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-neon-cyan/10 file:text-neon-cyan hover:file:bg-neon-cyan/20">
      <p class="mt-1 text-sm text-gray-500">MP4, MKV, WebM, or other video formats. Non-MP4 formats will be converted automatically.</p>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Title <span class="text-gray-500">(optional)</span></label>
      <input type="text" name="title" placeholder="Extracted from filename if blank"
             class="w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan px-3 py-2 text-sm border">
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Description <span class="text-gray-500">(optional)</span></label>
      <textarea name="description" rows="3" placeholder="Add a description..."
                class="w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan px-3 py-2 text-sm border"></textarea>
    </div>

    <div>
      <%= f.submit "Upload", class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink cursor-pointer" %>
    </div>
  <% end %>
</div>
