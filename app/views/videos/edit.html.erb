<div class="w-full max-w-lg">
  <h1 class="text-3xl font-bold font-display mb-6">Edit Video</h1>

  <%= form_with model: @video, class: "space-y-4" do |f| %>
    <% if @video.errors.any? %>
      <div class="bg-red-900/20 border border-red-800 rounded-lg p-4">
        <ul class="text-sm text-red-400">
          <% @video.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.text_field :title, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan px-3 py-2 text-sm border" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.text_area :description, rows: 3, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan px-3 py-2 text-sm border" %>
    </div>

    <div>
      <%= f.label :folder_id, "Folder", class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.collection_select :folder_id, @folders, :id, :name, { include_blank: "(No folder)" }, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan px-3 py-2 text-sm border" %>
    </div>

    <div>
      <%= f.submit "Save", class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink cursor-pointer" %>
      <%= link_to "Cancel", video_path(@video), class: "px-4 py-2 text-gray-400 hover:text-neon-cyan" %>
    </div>
  <% end %>
</div>
