<div class="w-full max-w-4xl">
  <div class="mb-6">
    <% if @video.folder %>
      <%= link_to "&larr; Back to #{@video.folder.name}".html_safe, folder_path(@video.folder), class: "text-neon-cyan hover:underline" %>
    <% else %>
      <%= link_to "&larr; Back".html_safe, tv_path(tab: "videos"), class: "text-neon-cyan hover:underline" %>
    <% end %>
  </div>

  <% if @video.status == "ready" && @video.file.attached? %>
    <div class="mb-6 relative bg-black rounded-xl overflow-hidden aspect-video"
         data-controller="video-player">
      <video data-video-player-target="video"
             class="w-full h-full"
             controls
             playsinline
             <% if @video.thumbnail.attached? %>poster="<%= url_for(@video.thumbnail) %>"<% end %>
             src="<%= stream_video_path(@video) %>">
      </video>
    </div>
  <% elsif @video.status == "processing" %>
    <div class="mb-6 bg-gray-800 rounded-xl aspect-video flex items-center justify-center">
      <div class="text-center">
        <div class="w-10 h-10 border-2 border-neon-cyan border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
        <p class="text-gray-400">Processing video...</p>
        <p class="text-xs text-gray-500 mt-1">This may take a few minutes.</p>
      </div>
    </div>
  <% elsif @video.status == "failed" %>
    <div class="mb-6 bg-gray-800 rounded-xl aspect-video flex items-center justify-center">
      <div class="text-center">
        <svg class="w-10 h-10 text-red-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
        </svg>
        <p class="text-red-400">Processing failed</p>
        <% if @video.error_message.present? %>
          <p class="text-xs text-gray-500 mt-1"><%= @video.error_message %></p>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="bg-gray-800 rounded-lg border border-gray-700 p-6">
    <h1 class="text-2xl font-bold font-display text-white"><%= @video.title %></h1>
    <% if @video.description.present? %>
      <p class="text-gray-400 mt-2"><%= @video.description %></p>
    <% end %>

    <% if @video.folder || @video.season_number || @video.episode_number %>
      <div class="mt-3 flex flex-wrap gap-2 text-xs">
        <% if @video.folder %>
          <%= link_to @video.folder.name, folder_path(@video.folder), class: "px-2 py-1 bg-gray-700 text-gray-500 rounded hover:text-neon-cyan" %>
        <% end %>
        <% if @video.season_number %>
          <span class="px-2 py-1 bg-gray-700 text-gray-500 rounded">Season <%= @video.season_number %></span>
        <% end %>
        <% if @video.episode_number %>
          <span class="px-2 py-1 bg-gray-700 text-gray-500 rounded">Episode <%= @video.episode_number %></span>
        <% end %>
      </div>
    <% end %>

    <div class="mt-4 text-sm text-gray-500 space-y-1">
      <% if @video.duration %><p>Duration: <%= format_duration(@video.duration) %></p><% end %>
      <% if @video.width && @video.height %><p>Resolution: <%= @video.width %>x<%= @video.height %></p><% end %>
      <% if @video.video_codec %><p>Codec: <%= @video.video_codec.upcase %></p><% end %>
      <% if @video.file_format %><p>Format: <%= @video.file_format.upcase %></p><% end %>
      <% if @video.bitrate %><p>Bitrate: <%= @video.bitrate %> kbps</p><% end %>
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <%= render "favorites/button", favorable: @video, favorited: Current.user.favorites.exists?(favorable: @video) %>
      <%= link_to "Edit", edit_video_path(@video), class: "px-4 py-2 bg-gray-700 text-white rounded-lg hover:bg-gray-600" %>
      <%= button_to "Delete", video_path(@video), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700" %>
    </div>
  </div>
</div>
