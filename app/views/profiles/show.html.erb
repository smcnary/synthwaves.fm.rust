<div class="mx-auto md:w-2/3 w-full">
  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-laser-green/10 border border-laser-green/20 mb-5 text-laser-green font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold font-display text-4xl text-white">Profile</h1>

  <div class="mt-6 bg-gray-800 shadow-sm rounded-lg border border-gray-700">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-700">
      <p class="text-sm font-medium text-gray-400">Name</p>
      <p class="mt-1 text-white"><%= @user.name.presence || "Not set" %></p>
    </div>

    <div class="px-4 py-5 sm:px-6 border-b border-gray-700">
      <p class="text-sm font-medium text-gray-400">Email</p>
      <p class="mt-1 text-white"><%= @user.email_address %></p>
    </div>

    <div class="px-4 py-5 sm:px-6 border-b border-gray-700">
      <p class="text-sm font-medium text-gray-400">Subsonic Password</p>
      <p class="mt-1 text-white"><%= @user.subsonic_password.present? ? "********" : "Not set" %></p>
    </div>

    <div class="px-4 py-5 sm:px-6">
      <p class="text-sm font-medium text-gray-400">Theme</p>
      <p class="mt-1 text-white"><%= Themeable::THEMES.dig(@user.theme, :label) %></p>
    </div>
  </div>

  <div class="mt-6">
    <%= link_to "Edit Profile", edit_profile_path, class: "rounded-md px-3.5 py-2.5 bg-neon-pink hover:shadow-neon-pink text-white inline-block font-medium" %>
  </div>

  <% if turbo_native_app? %>
    <div class="mt-6">
      <%= button_to "Sign Out", session_path, method: :delete, class: "rounded-md px-3.5 py-2.5 bg-red-600 hover:bg-red-700 text-white inline-block font-medium cursor-pointer" %>
    </div>
  <% end %>

  <h2 class="font-bold font-display text-2xl text-white mt-10">Data</h2>

  <div class="mt-4 bg-gray-800 shadow-sm rounded-lg border border-gray-700 px-4 py-5 sm:px-6">
    <p class="text-sm text-gray-400 mb-4">Export your entire music library as a ZIP archive.</p>
    <div class="flex flex-wrap items-center gap-3">
      <%= button_to downloads_path(downloadable_type: "Library"), class: "inline-flex items-center gap-1.5 px-3.5 py-2.5 bg-neon-purple/30 text-white rounded-md text-sm font-medium hover:bg-neon-purple/50 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Export Library
      <% end %>
      <%= link_to downloads_path, class: "inline-flex items-center gap-1.5 px-3.5 py-2.5 text-gray-400 hover:text-white text-sm font-medium transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/></svg>
        View Downloads
      <% end %>
    </div>
  </div>

  <h2 class="font-bold font-display text-2xl text-white mt-10">Delete Account</h2>

  <div class="mt-4 bg-gray-800 shadow-sm rounded-lg border border-red-500/30 px-4 py-5 sm:px-6">
    <p class="text-sm text-gray-400 mb-4">Permanently delete your account and all associated data. This action cannot be undone.</p>
    <%= button_to registration_path, method: :delete, class: "inline-flex items-center gap-1.5 px-3.5 py-2.5 bg-red-600 hover:bg-red-700 text-white rounded-md text-sm font-medium transition-colors cursor-pointer", data: { turbo_confirm: "Are you sure you want to delete your account? All your data will be permanently removed." } do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
      Delete My Account
    <% end %>
  </div>
</div>
