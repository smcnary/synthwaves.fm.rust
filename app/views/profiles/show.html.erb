<div class="mx-auto md:w-2/3 w-full">
  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-laser-green/10 border border-laser-green/20 mb-5 text-laser-green font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold font-display text-4xl text-white">Profile</h1>

  <div class="mt-6 bg-gray-800 shadow-sm rounded-lg border border-gray-700">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-700">
      <p class="text-sm font-medium text-gray-400">Name</p>
      <p class="mt-1 text-white"><%= @user.name.presence || "Not set" %></p>
    </div>

    <div class="px-4 py-5 sm:px-6">
      <p class="text-sm font-medium text-gray-400">Email</p>
      <p class="mt-1 text-white"><%= @user.email_address %></p>
    </div>
  </div>

  <div class="mt-6">
    <%= link_to "Edit Profile", edit_profile_path, class: "rounded-md px-3.5 py-2.5 bg-neon-pink hover:shadow-neon-pink text-white inline-block font-medium" %>
  </div>
</div>
