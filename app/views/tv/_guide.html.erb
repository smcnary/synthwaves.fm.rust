<div data-controller="tv-guide tv-remote"
     data-tv-guide-window-start-value="<%= @window_start.to_i %>"
     data-tv-guide-window-end-value="<%= @window_end.to_i %>"
     data-tv-guide-pixels-per-minute-value="7"
     data-tv-remote-channels-value="<%= retro_tv_channels_json(@channels, @programmes_by_channel) %>">
  <%# Search and country filter %>
  <div class="flex flex-col sm:flex-row gap-3 mb-4">
    <%= form_with url: tv_path(tab: "guide"), method: :get, class: "flex-1" do |f| %>
      <%= hidden_field_tag :tab, "guide" %>
      <%= hidden_field_tag :category, params[:category] %>
      <%= hidden_field_tag :country, params[:country] %>
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search channels..."
               class="w-full pl-9 pr-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan focus:border-transparent placeholder-gray-500">
      </div>
    <% end %>
    <% if @countries.any? %>
      <%= form_with url: tv_path(tab: "guide"), method: :get do %>
        <%= hidden_field_tag :tab, "guide" %>
        <%= hidden_field_tag :category, params[:category] %>
        <%= hidden_field_tag :q, params[:q] %>
        <select name="country" onchange="this.form.requestSubmit()"
                class="px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan">
          <option value="">All Countries</option>
          <% @countries.each do |country| %>
            <option value="<%= country %>" <%= 'selected' if params[:country] == country %>><%= country %></option>
          <% end %>
        </select>
      <% end %>
    <% end %>
    <% if @categories.any? %>
      <%= form_with url: tv_path(tab: "guide"), method: :get do %>
        <%= hidden_field_tag :tab, "guide" %>
        <%= hidden_field_tag :q, params[:q] %>
        <%= hidden_field_tag :country, params[:country] %>
        <select name="category" onchange="this.form.requestSubmit()"
                class="px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan">
          <option value="">All Categories</option>
          <% @categories.each do |category| %>
            <option value="<%= category.slug %>" <%= 'selected' if params[:category] == category.slug %>><%= category.name %></option>
          <% end %>
        </select>
      <% end %>
    <% end %>
  </div>
  <%# TV Guide navigation %>
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-2">
      <button type="button" data-action="tv-guide#navigateBack"
          class="px-3 py-1.5 text-sm border border-gray-600 text-gray-300 rounded-lg hover:border-neon-cyan hover:text-neon-cyan transition-colors">
        &larr; Back
      </button>
      <button type="button" data-action="tv-guide#jumpToNow"
          class="px-3 py-1.5 text-sm bg-neon-cyan/10 border border-neon-cyan/30 text-neon-cyan rounded-lg hover:bg-neon-cyan/20 transition-colors">
        Now
      </button>
      <button type="button" data-action="tv-guide#navigateForward"
          class="px-3 py-1.5 text-sm border border-gray-600 text-gray-300 rounded-lg hover:border-neon-cyan hover:text-neon-cyan transition-colors">
        Forward &rarr;
      </button>
    </div>
    <div class="text-sm text-gray-400">
      <%= @window_start.strftime("%-I:%M %p") %> &ndash; <%= @window_end.strftime("%-I:%M %p %Z") %>
    </div>
  </div>
  <%# TV Guide Grid %>
  <% if @channels.any? %>
    <div class="border border-gray-700/50 rounded-xl overflow-hidden bg-gray-900/80">
      <div class="flex">
        <%# Sticky channel column %>
        <div class="flex-shrink-0 w-[160px] z-20 bg-gray-900">
          <%# Time header spacer %>
          <div class="h-10 border-b border-gray-700/50 bg-gray-900"></div>
          <%# Channel rows %>
          <% @channels.each_with_index do |channel, index| %>
            <div class="h-16 border-b border-gray-700/30 flex items-center gap-2 px-3 bg-gray-900 hover:bg-gray-800 transition-colors cursor-pointer"
             data-action="click->tv-remote#tune"
              data-tv-remote-url-param="<%= channel.stream_url %>"
              data-tv-remote-name-param="<%= channel.name %>"
              data-tv-remote-index-param="<%= index %>">
              <div class="w-8 h-8 rounded bg-gray-700 flex items-center justify-center overflow-hidden flex-shrink-0">
                <% if channel.logo_url.present? %>
                  <img src="<%= channel.logo_url %>" alt="" class="w-full h-full object-contain" loading="lazy">
                <% else %>
                  <span class="text-[10px] font-bold text-white"><%= channel.name.scan(/[A-Z0-9]/).first(3).join.presence || channel.name[0..1].upcase %></span>
                <% end %>
              </div>
              <span class="text-xs font-medium text-white truncate flex-1"><%= channel.name %></span>
              <div class="flex-shrink-0" onclick="event.stopPropagation()">
                <%= render "favorites/button", favorable: channel, favorited: @favorited_channel_ids.include?(channel.id) %>
              </div>
            </div>
          <% end %>
        </div>
        <%# Scrollable programme grid %>
        <div class="flex-1 overflow-x-auto" data-tv-guide-target="grid">
          <div class="relative" style="width: <%= guide_grid_width(@window_start, @window_end) %>px; min-width: 100%;">
            <%# Time header %>
            <div class="h-10 border-b border-gray-700/50 relative bg-gray-900/90">
              <% guide_time_slots(@window_start, @window_end).each do |slot| %>
                <% left = time_slot_left_px(slot, @window_start) %>
                <div class="absolute top-0 h-full flex items-center border-l border-gray-700/30 pl-2"
                 style="left: <%= left %>px;">
                  <span class="text-xs text-gray-400 whitespace-nowrap"><%= slot.strftime("%-I:%M %p") %></span>
                </div>
              <% end %>
            </div>
            <%# Programme rows %>
            <% @channels.each_with_index do |channel, index| %>
              <div class="h-16 border-b border-gray-700/30 relative">
                <% programmes = @programmes_by_channel[channel.tvg_id] || [] %>
                <% if programmes.any? %>
                  <% programmes.each do |programme| %>
                    <% left = programme_left_px(programme, @window_start) %>
                    <% width = programme_width_px(programme, @window_start, @window_end) %>
                    <% next if width < 2 %>
                    <div class="group/prog absolute top-1 bottom-1 rounded-md px-2 py-1 overflow-hidden cursor-pointer transition-all duration-150
                            <%= programme.live? ? 'bg-gray-800/90 border border-neon-cyan/30 shadow-[0_0_8px_rgba(0,255,255,0.1)]' : 'bg-gray-800 border border-gray-600 hover:border-neon-cyan/50 hover:bg-gray-700' %>"
                     style="left: <%= left %>px; width: <%= width %>px;"
                     data-action="click->tv-remote#tune"
                      data-tv-remote-url-param="<%= channel.stream_url %>"
                      data-tv-remote-name-param="<%= channel.name %>"
                      data-tv-remote-index-param="<%= index %>"
                      title="<%= programme.title %><%= " - #{programme.subtitle}" if programme.subtitle.present? %>">
                      <div class="text-xs font-medium text-white truncate leading-tight"><%= programme.title %></div>
                      <% if programme.subtitle.present? && width > 100 %>
                        <div class="text-[10px] text-gray-400 truncate leading-tight"><%= programme.subtitle %></div>
                      <% end %>
                      <% if programme.live? && width > 60 %>
                        <div class="mt-0.5 h-1 bg-gray-700 rounded-full overflow-hidden">
                          <div class="h-full bg-neon-cyan rounded-full" style="width: <%= programme.progress_percentage %>%"></div>
                        </div>
                      <% end %>
                      <% rec_status = @recording_by_programme_id[programme.id] %>
                      <% if rec_status %>
                        <div class="absolute top-0.5 right-0.5" onclick="event.stopPropagation()">
                          <%= render "recordings/record_button", channel: channel, programme: programme, status: rec_status, size: :small %>
                        </div>
                      <% elsif programme.live? || programme.starts_at > Time.current %>
                        <div class="absolute top-0.5 right-0.5 opacity-0 group-hover/prog:opacity-100 transition-opacity" onclick="event.stopPropagation()">
                          <%= render "recordings/record_button", channel: channel, programme: programme, size: :small %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                <% else %>
                  <div class="absolute inset-0 flex items-center px-3">
                    <span class="text-xs text-gray-600 italic">No schedule info</span>
                  </div>
                <% end %>
              </div>
            <% end %>
            <%# Current time marker %>
            <div data-tv-guide-target="timeMarker"
             class="absolute top-0 bottom-0 w-0.5 bg-neon-cyan z-10 pointer-events-none"
             style="display: none; box-shadow: 0 0 8px rgba(0, 255, 255, 0.5), 0 0 16px rgba(0, 255, 255, 0.2);">
              <div class="w-2 h-2 bg-neon-cyan rounded-full -ml-[3px] -mt-1"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="text-center py-16 text-gray-400">
      <svg class="w-16 h-16 mx-auto mb-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
      </svg>
      <p class="text-lg mb-2">No channels found</p>
      <p>Try adjusting your filters or search query.</p>
    </div>
  <% end %>
</div>
