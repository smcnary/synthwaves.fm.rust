<%= turbo_stream_from "recordings_#{Current.user.id}" %>

<%= render CollectionLayoutComponent.new(
  collection: @recordings,
  page_key: "tv-recordings",
  form_url: tv_path,
  turbo_frame: "tv-content",
  tab: "recordings",
  placeholder: "Search recordings...",
  sort_options: Recording::SORT_OPTIONS,
  sort: @sort,
  direction: @direction,
  query: @query,
  pagy: @pagy,
  view_toggle: false,
  container_classes: "space-y-3",
  empty_label: "recordings"
) do |c| %>
  <% c.with_filters do %>
    <label for="status" class="text-sm text-gray-400 font-medium">Status</label>
    <select name="status" id="status" data-action="change->search#submit" class="text-sm rounded-lg border border-gray-600 bg-gray-700 text-white px-3 py-2 focus:outline-neon-cyan">
      <option value="">All</option>
      <% Recording::STATUSES.each do |s| %>
        <option value="<%= s %>" <%= "selected" if s == @status %>><%= s.capitalize %></option>
      <% end %>
    </select>
  <% end %>
  <% @recordings.each do |recording| %>
    <%= render "recordings/recording", recording: recording %>
  <% end %>
<% end %>
