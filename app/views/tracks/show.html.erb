<% content_for :meta_title, "#{@track.title} by #{@track.artist.name} — synthwaves.fm" %>
<% content_for :meta_description, "#{@track.title} from #{@track.album.title} by #{@track.artist.name}#{@track.duration ? " (#{format_duration(@track.duration)})" : ""}" %>
<% if @track.album.cover_image.attached? %>
  <% content_for :meta_image, og_image_url_for(@track.album.cover_image) %>
<% end %>
<% content_for :meta_type, "music.song" %>

<div class="w-full">
  <div class="mb-6">
    <%= render Button::Component.new(label: "← Back", behavior: :navigation, link_url: tracks_path, style: :link) %>
  </div>

  <% if @track.youtube? %>
    <%# === WITH VIDEO: side-by-side layout === %>
    <div class="flex flex-col lg:flex-row gap-6">
      <%# Left: Music video (dominant) %>
      <div class="flex-1 min-w-0">
        <div class="overflow-hidden rounded-lg">
          <%= render MusicVideo::Component.new(track_id: @track.id, youtube_video_id: @track.youtube_video_id, max_height: "max-h-[75vh]") %>
        </div>
      </div>

      <%# Right: Track info + lyrics stacked %>
      <div class="lg:w-80 xl:w-96 flex flex-col gap-4 shrink-0">
        <%# Compact track info %>
        <div class="bg-gray-800 rounded-lg border border-gray-700 p-5">
          <div class="flex items-start gap-4">
            <% if @track.album.cover_image.attached? %>
              <%= image_tag @track.album.cover_image, class: "w-16 h-16 rounded-lg object-cover shrink-0" %>
            <% else %>
              <div class="w-16 h-16 rounded-lg bg-gray-700 flex items-center justify-center shrink-0">
                <svg class="w-8 h-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"/></svg>
              </div>
            <% end %>
            <div class="min-w-0">
              <h1 class="text-lg font-bold font-display text-white leading-tight truncate"><%= @track.title %></h1>
              <p class="text-sm text-gray-400 truncate"><%= link_to @track.artist.name, artist_path(@track.artist), class: "hover:underline" %></p>
              <p class="text-sm text-gray-400 truncate"><%= link_to @track.album.title, album_path(@track.album), class: "hover:underline" %></p>
            </div>
          </div>

          <div class="mt-3 flex flex-wrap gap-x-4 gap-y-0.5 text-xs text-gray-500">
            <% if @track.track_number %><span>Track <%= @track.track_number %></span><% end %>
            <% if @track.duration %><span><%= format_duration(@track.duration) %></span><% end %>
            <% if @track.bitrate %><span><%= @track.bitrate %> kbps</span><% end %>
            <% if @track.file_format %><span><%= @track.file_format.upcase %></span><% end %>
          </div>

          <div class="mt-3">
            <%= render "taggings/tags", taggable: @track %>
          </div>

          <div class="mt-3">
            <%= render "playlist_tracks/memberships", playlists: @track_playlists %>
          </div>

          <div class="mt-3 flex items-center gap-2">
            <button class="w-9 h-9 rounded-full bg-neon-pink text-white flex items-center justify-center hover:shadow-neon-pink"
                    title="Play"
                    data-controller="song-row"
                    data-song-row-track-id-value="<%= @track.id %>"
                    data-song-row-title-value="<%= @track.title %>"
                    data-song-row-artist-value="<%= @track.artist.name %>"
                    <% if @track.audio_file.attached? %>
                    data-song-row-stream-url-value="<%= stream_track_path(@track) %>"
                    <% end %>
                    <% if @track.youtube? %>
                    data-song-row-youtube-video-id-value="<%= @track.youtube_video_id %>"
                    <% end %>
                    data-action="song-row#play">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/></svg>
            </button>
            <%= render "favorites/button", favorable: @track, favorited: Current.user.favorites.exists?(favorable: @track) %>
            <%= render "playlist_tracks/add_menu", track: @track, playlists: current_user_playlists, menu_class: "left-0" %>
            <div class="w-px h-5 bg-gray-600"></div>
            <% if @track.audio_file.attached? %>
              <%= link_to download_track_path(@track), class: "p-1 text-gray-400 hover:text-neon-cyan", title: "Download" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              <% end %>
            <% end %>
            <% if @track.youtube? %>
              <%= button_to enrich_track_path(@track), method: :post, class: "p-1 text-gray-400 hover:text-neon-cyan", title: "Enrich metadata" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              <% end %>
            <% end %>
            <%= link_to edit_track_path(@track), class: "p-1 text-gray-400 hover:text-neon-cyan", title: "Edit" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            <% end %>
            <%= button_to track_path(@track), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "p-1 text-gray-400 hover:text-red-500", title: "Delete" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            <% end %>
          </div>
        </div>

        <%# Lyrics %>
        <div class="bg-gray-800 rounded-lg border border-gray-700 p-5 flex-1 min-h-0">
          <%= render Lyrics::Component.new(track_id: @track.id, show_header: true, max_height: "max-h-[50vh]") %>
        </div>
      </div>
    </div>

  <% else %>
    <%# === WITHOUT VIDEO: original two-column layout === %>
    <div class="flex flex-col lg:flex-row gap-6">
      <div class="flex-1 max-w-2xl">
        <div class="bg-gray-800 rounded-lg border border-gray-700 p-6">
          <div class="flex flex-col sm:flex-row items-start gap-4 sm:gap-6">
            <% if @track.album.cover_image.attached? %>
              <%= image_tag @track.album.cover_image, class: "w-24 h-24 sm:w-32 sm:h-32 rounded-lg object-cover" %>
            <% else %>
              <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-lg bg-gray-700 flex items-center justify-center">
                <svg class="w-12 h-12 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"/></svg>
              </div>
            <% end %>
            <div>
              <h1 class="text-2xl font-bold font-display text-white"><%= @track.title %></h1>
              <p class="text-gray-400"><%= link_to @track.artist.name, artist_path(@track.artist), class: "hover:underline" %></p>
              <p class="text-gray-400"><%= link_to @track.album.title, album_path(@track.album), class: "hover:underline" %></p>

              <div class="mt-4 text-sm text-gray-400 space-y-1">
                <% if @track.track_number %><p>Track <%= @track.track_number %></p><% end %>
                <% if @track.duration %><p>Duration: <%= format_duration(@track.duration) %></p><% end %>
                <% if @track.bitrate %><p>Bitrate: <%= @track.bitrate %> kbps</p><% end %>
                <% if @track.file_format %><p>Format: <%= @track.file_format.upcase %></p><% end %>
              </div>

              <div class="mt-4">
                <%= render "taggings/tags", taggable: @track %>
              </div>

              <div class="mt-4">
                <%= render "playlist_tracks/memberships", playlists: @track_playlists %>
              </div>

              <div class="mt-4 flex items-center gap-3">
                <button class="w-10 h-10 rounded-full bg-neon-pink text-white flex items-center justify-center hover:shadow-neon-pink"
                        title="Play"
                        data-controller="song-row"
                        data-song-row-track-id-value="<%= @track.id %>"
                        data-song-row-title-value="<%= @track.title %>"
                        data-song-row-artist-value="<%= @track.artist.name %>"
                        <% if @track.audio_file.attached? %>
                        data-song-row-stream-url-value="<%= stream_track_path(@track) %>"
                        <% end %>
                        data-action="song-row#play">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/></svg>
                </button>
                <%= render "favorites/button", favorable: @track, favorited: Current.user.favorites.exists?(favorable: @track) %>
                <%= render "playlist_tracks/add_menu", track: @track, playlists: current_user_playlists, menu_class: "left-0" %>
                <div class="w-px h-6 bg-gray-600"></div>
                <% if @track.audio_file.attached? %>
                  <%= link_to download_track_path(@track), class: "p-1.5 text-gray-400 hover:text-neon-cyan", title: "Download" do %>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                  <% end %>
                <% end %>
                <%= link_to edit_track_path(@track), class: "p-1.5 text-gray-400 hover:text-neon-cyan", title: "Edit" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                <% end %>
                <%= button_to track_path(@track), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "p-1.5 text-gray-400 hover:text-red-500", title: "Delete" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="lg:w-80 lg:mt-12">
        <div class="bg-gray-800 rounded-lg border border-gray-700 p-5">
          <%= render Lyrics::Component.new(track_id: @track.id, show_header: true) %>
        </div>
      </div>
    </div>
  <% end %>
</div>
