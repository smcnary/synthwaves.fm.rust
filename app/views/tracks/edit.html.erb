<div class="w-full max-w-lg">
  <h1 class="text-3xl font-bold font-display mb-6">Edit Track</h1>

  <%= form_with model: @track, class: "space-y-4" do |f| %>
    <% if @track.errors.any? %>
      <div class="bg-red-900/20 border border-red-800 rounded-lg p-4">
        <ul class="text-sm text-red-400">
          <% @track.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.text_field :title, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan" %>
    </div>

    <div>
      <%= f.label :track_number, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.number_field :track_number, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan" %>
    </div>

    <div>
      <%= f.label :disc_number, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.number_field :disc_number, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan" %>
    </div>

    <div>
      <%= f.label :lyrics, class: "block text-sm font-medium text-gray-400 mb-1" %>
      <%= f.text_area :lyrics, rows: 8, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white focus:outline-neon-cyan font-mono text-sm", placeholder: "Paste lyrics here..." %>
    </div>

    <div>
      <%= f.submit "Save", class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink cursor-pointer" %>
      <%= link_to "Cancel", track_path(@track), class: "px-4 py-2 text-gray-400 hover:text-neon-cyan" %>
    </div>
  <% end %>
</div>
