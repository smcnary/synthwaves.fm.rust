<div class="w-full">
  <h1 class="text-3xl font-bold mb-6">Podcasts</h1>

  <% if @artists.any? %>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
      <% @artists.each do |artist| %>
        <%= link_to podcast_path(artist), class: "group" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4 hover:shadow-lg transition-shadow">
            <% last_album = artist.albums.max_by(&:created_at) %>
            <% if last_album&.cover_image&.attached? %>
              <%= image_tag last_album.cover_image, class: "w-full aspect-square rounded-lg object-cover mb-3", loading: "lazy" %>
            <% else %>
              <div class="w-full aspect-square rounded-lg bg-gray-200 dark:bg-gray-700 flex items-center justify-center mb-3">
                <svg class="w-12 h-12 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7 4a3 3 0 016 0v4a3 3 0 11-6 0V4zm4 10.93A7.001 7.001 0 0017 8a1 1 0 10-2 0A5 5 0 015 8a1 1 0 00-2 0 7.001 7.001 0 006 6.93V17H6a1 1 0 100 2h8a1 1 0 100-2h-3v-2.07z" clip-rule="evenodd"/>
                </svg>
              </div>
            <% end %>
            <div class="text-center">
              <div class="font-medium text-gray-900 dark:text-white group-hover:text-blue-600 truncate"><%= artist.name %></div>
              <div class="text-sm text-gray-500"><%= pluralize(artist.tracks.size, "episode") %></div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500">No podcasts yet. Import a podcast playlist from YouTube to get started.</p>
  <% end %>
</div>
