<div class="w-full">
  <div class="mb-6">
    <%= link_to "&larr; Podcasts".html_safe, podcasts_path, class: "text-neon-cyan hover:underline" %>
  </div>

  <h1 class="text-3xl font-bold font-display mb-6"><%= @artist.name %></h1>

  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
    <% @albums.each do |album| %>
      <%= link_to album_path(album), class: "group" do %>
        <div class="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden hover:shadow-lg transition-shadow">
          <% if album.cover_image.attached? %>
            <%= image_tag album.cover_image, class: "w-full aspect-square object-cover", loading: "lazy" %>
          <% else %>
            <div class="w-full aspect-square bg-gray-700 flex items-center justify-center">
              <svg class="w-12 h-12 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7 4a3 3 0 016 0v4a3 3 0 11-6 0V4zm4 10.93A7.001 7.001 0 0017 8a1 1 0 10-2 0A5 5 0 015 8a1 1 0 00-2 0 7.001 7.001 0 006 6.93V17H6a1 1 0 100 2h8a1 1 0 100-2h-3v-2.07z" clip-rule="evenodd"/>
              </svg>
            </div>
          <% end %>
          <div class="p-3">
            <div class="font-medium text-white group-hover:text-neon-cyan truncate"><%= album.title %></div>
            <div class="text-sm text-gray-500"><%= pluralize(album.tracks.size, "episode") %></div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
