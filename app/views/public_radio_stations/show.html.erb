<% content_for :title, "#{@station.playlist.name} — synthwaves.fm Radio" %>
<% content_for :meta_title, "#{@station.playlist.name} — Live on synthwaves.fm" %>
<% content_for :meta_description, "Listen to #{@station.playlist.name} — #{@station.playlist.tracks.count} tracks streaming at #{@station.bitrate}kbps on synthwaves.fm" %>

<%= turbo_stream_from "radio_station_public_#{@station.id}" %>

<div class="min-h-screen flex flex-col items-center justify-center px-4 py-12 relative">
  <%# Decorative radial glow behind the card %>
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full"
         style="background: radial-gradient(circle, color-mix(in srgb, var(--color-neon-pink) 15%, transparent) 0%, transparent 70%);"></div>
  </div>

  <div class="relative z-10 w-full max-w-md flex flex-col items-center">
    <%# Logo %>
    <div class="mb-10">
      <%= link_to root_path do %>
        <%= render(Logo::Component.new(size: :md, icon: true)) %>
      <% end %>
    </div>

    <%# Album Art %>
    <div class="relative mb-8 group">
      <% if @station.current_track&.album&.cover_image&.attached? %>
        <div class="w-64 h-64 sm:w-72 sm:h-72 rounded-2xl overflow-hidden shadow-2xl ring-1 ring-white/10"
             style="box-shadow: 0 0 40px color-mix(in srgb, var(--color-neon-pink) 20%, transparent), 0 0 80px color-mix(in srgb, var(--color-neon-purple) 10%, transparent), 0 25px 50px rgba(0,0,0,0.5);">
          <%= image_tag @station.current_track.album.cover_image, class: "w-full h-full object-cover" %>
        </div>
      <% else %>
        <div class="w-64 h-64 sm:w-72 sm:h-72 rounded-2xl bg-gray-800 border border-gray-700 flex items-center justify-center"
             style="box-shadow: 0 0 40px color-mix(in srgb, var(--color-neon-pink) 15%, transparent), 0 25px 50px rgba(0,0,0,0.5);">
          <svg class="w-20 h-20 text-gray-600" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
          </svg>
        </div>
      <% end %>
    </div>

    <%# Station Name & Status %>
    <div class="text-center mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold font-display text-white mb-2"><%= @station.playlist.name %></h1>
      <div id="public_status_<%= @station.id %>" class="inline-block">
        <%= render "radio_stations/status_badge", station: @station %>
      </div>
    </div>

    <%# Now Playing %>
    <div id="now_playing_<%= @station.id %>" class="w-full mb-8">
      <% if @station.current_track %>
        <div class="text-center">
          <p class="text-sm text-gray-500 uppercase tracking-widest mb-1">Now Playing</p>
          <p class="text-white font-medium text-lg"><%= @station.current_track.title %></p>
          <p class="text-gray-400"><%= @station.current_track.artist.name %> &middot; <%= @station.current_track.album.title %></p>
        </div>
      <% end %>
    </div>

    <%# Listen Button %>
    <% if @station.active? || @station.idle? %>
      <div class="w-full mb-8" data-controller="radio-player" data-radio-player-url-value="<%= @station.listen_url %>">
        <button type="button"
                data-action="click->radio-player#toggle"
                data-radio-player-target="toggleButton"
                class="w-full py-4 rounded-xl font-display font-bold text-lg tracking-wide text-white bg-neon-pink hover:shadow-neon-pink transition-all duration-300 flex items-center justify-center gap-3">
          <span data-radio-player-target="playIcon">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/></svg>
          </span>
          <span data-radio-player-target="pauseIcon" class="hidden">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.5 3a1.5 1.5 0 00-1.5 1.5v11A1.5 1.5 0 005.5 17h1A1.5 1.5 0 008 15.5v-11A1.5 1.5 0 006.5 3h-1zm8 0a1.5 1.5 0 00-1.5 1.5v11a1.5 1.5 0 001.5 1.5h1a1.5 1.5 0 001.5-1.5v-11A1.5 1.5 0 0014.5 3h-1z" clip-rule="evenodd"/></svg>
          </span>
          <span data-radio-player-target="label">Listen Live</span>
        </button>
        <audio data-radio-player-target="audio" preload="none"></audio>
      </div>
    <% elsif @station.starting? %>
      <div class="w-full mb-8">
        <div class="w-full py-4 rounded-xl font-display font-bold text-lg tracking-wide text-gray-400 bg-gray-800 border border-gray-700 flex items-center justify-center gap-3">
          <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          Starting Up...
        </div>
      </div>
    <% else %>
      <div class="w-full mb-8">
        <div class="w-full py-4 rounded-xl font-display text-lg tracking-wide text-gray-500 bg-gray-800/50 border border-gray-700/50 text-center">
          Station Offline
        </div>
      </div>
    <% end %>

    <%# Station Details %>
    <div class="w-full grid grid-cols-3 gap-4 text-center mb-10">
      <div class="bg-gray-800/60 backdrop-blur rounded-lg border border-gray-700/50 py-3 px-2">
        <p class="text-xl font-bold font-display text-white"><%= @station.listener_count %></p>
        <p class="text-xs text-gray-500 uppercase tracking-wider mt-0.5">Listeners</p>
      </div>
      <div class="bg-gray-800/60 backdrop-blur rounded-lg border border-gray-700/50 py-3 px-2">
        <p class="text-xl font-bold font-display text-white"><%= @station.playlist.tracks.count %></p>
        <p class="text-xs text-gray-500 uppercase tracking-wider mt-0.5">Tracks</p>
      </div>
      <div class="bg-gray-800/60 backdrop-blur rounded-lg border border-gray-700/50 py-3 px-2">
        <p class="text-xl font-bold font-display text-white"><%= @station.bitrate %></p>
        <p class="text-xs text-gray-500 uppercase tracking-wider mt-0.5">kbps</p>
      </div>
    </div>

    <%# Footer %>
    <p class="text-gray-600 text-sm">
      Powered by <%= link_to "synthwaves.fm", root_path, class: "text-gray-500 hover:text-neon-cyan transition-colors" %>
    </p>
  </div>
</div>
