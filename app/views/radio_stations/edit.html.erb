<div class="w-full max-w-lg">
  <div class="mb-6">
    <%= link_to "&larr; Back".html_safe, radio_station_path(@station), class: "text-neon-cyan hover:underline" %>
  </div>

  <h1 class="text-3xl font-bold font-display mb-8">Station Settings</h1>

  <div class="bg-gray-800 rounded-lg border border-gray-700 p-6">
    <%= form_with model: @station, class: "space-y-5" do |f| %>
      <% if @station.errors.any? %>
        <div class="bg-red-900/20 border border-red-800 rounded-lg p-4">
          <ul class="text-sm text-red-400 list-disc list-inside">
            <% @station.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :image, "Station Image", class: "block text-sm font-medium text-gray-400 mb-1" %>
        <p class="text-xs text-gray-500 mb-2">Displayed when the current track has no album art.</p>
        <% if @station.image.attached? %>
          <div class="mb-2 flex items-center gap-3">
            <%= image_tag @station.image, class: "w-16 h-16 rounded-lg object-cover" %>
            <span class="text-sm text-gray-400">Current image</span>
          </div>
        <% end %>
        <%= f.file_field :image, accept: "image/*",
            class: "w-full text-sm text-gray-400 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:bg-gray-700 file:text-gray-300 file:cursor-pointer hover:file:bg-gray-600" %>
      </div>

      <div>
        <%= f.label :playback_mode, class: "block text-sm font-medium text-gray-400 mb-1" %>
        <%= f.select :playback_mode, RadioStation::PLAYBACK_MODES.map { |m| [m.capitalize, m] },
            {}, class: "w-full rounded-lg bg-gray-800 border border-gray-700 px-3 py-2 text-white focus:outline-neon-cyan" %>
      </div>

      <div>
        <%= f.label :bitrate, "Bitrate (kbps)", class: "block text-sm font-medium text-gray-400 mb-1" %>
        <%= f.select :bitrate, RadioStation::BITRATES.map { |b| ["#{b} kbps", b] },
            {}, class: "w-full rounded-lg bg-gray-800 border border-gray-700 px-3 py-2 text-white focus:outline-neon-cyan" %>
      </div>

      <div class="flex items-center gap-3">
        <%= f.check_box :crossfade, class: "rounded bg-gray-700 border-gray-600 text-neon-pink focus:ring-neon-pink" %>
        <%= f.label :crossfade, "Enable crossfade", class: "text-sm text-gray-300" %>
      </div>

      <div>
        <%= f.label :crossfade_duration, "Crossfade duration (seconds)", class: "block text-sm font-medium text-gray-400 mb-1" %>
        <%= f.number_field :crossfade_duration, step: 0.5, min: 0, max: 10,
            class: "w-full rounded-lg bg-gray-800 border border-gray-700 px-3 py-2 text-white focus:outline-neon-cyan" %>
      </div>

      <div class="pt-2 flex gap-3">
        <%= f.submit "Save", class: "px-4 py-2 bg-neon-pink text-white rounded-lg hover:shadow-neon-pink cursor-pointer" %>
        <%= link_to "Cancel", radio_station_path(@station), class: "px-4 py-2 bg-gray-700 text-gray-300 rounded-lg hover:bg-gray-600" %>
      </div>
    <% end %>
  </div>
</div>
