<nav class="bg-slate-900 backdrop-blur-sm border-b border-neon-cyan/20">
  <div class="container mx-auto py-3 px-2 md:px-0">
    <div class="flex items-center justify-between">
      <!-- Left side: App name + nav -->
      <div class="flex items-center space-x-4">
        <%= link_to root_path do %>
          <%= render(Logo::Component.new(size: :md, icon: true, text: false)) %>
        <% end %>
        <% if authenticated? %>
          <nav class="hidden md:flex items-center space-x-3 text-sm">
            <%= render Button::Component.new(label: "Listen", behavior: :navigation, link_url: music_path, style: :nav_link) %>
            <%= render Button::Component.new(label: "Watch", behavior: :navigation, link_url: tv_path, style: :nav_link) %>
            <%= render Button::Component.new(label: "Stats", behavior: :navigation, link_url: stats_path, style: :nav_link) %>
          </nav>
        <% end %>
      </div>
      <% if authenticated? %>
        <!-- Desktop search widget -->
        <div class="hidden md:block relative" data-controller="global-search" data-global-search-url-value="<%= search_dropdown_path %>">
          <div class="relative">
            <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" placeholder="Search..."
                   class="w-48 lg:w-64 pl-8 pr-3 py-1.5 text-sm rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan focus:border-transparent placeholder-gray-500"
                   data-global-search-target="input"
                   data-action="input->global-search#search keydown->global-search#keydown">
          </div>
          <div class="hidden absolute top-full left-0 right-0 mt-1 bg-gray-800 rounded-lg shadow-lg border border-gray-700 z-50 max-h-96 overflow-y-auto"
               data-global-search-target="dropdown">
            <turbo-frame id="navbar-search-results" data-global-search-target="frame"></turbo-frame>
          </div>
        </div>
      <% end %>
      <!-- Right side: User Dropdown or Auth links -->
      <% if authenticated? %>
        <%= render Dropdown::Component.new(position: :right) do |dropdown| %>
          <% dropdown.with_trigger do %>
            <span class="flex items-center gap-2 text-sm font-medium text-white hover:text-neon-cyan">
              <span class="max-w-[120px] sm:max-w-none truncate"><%= Current.user.name || Current.user.email_address %></span>
              <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </span>
          <% end %>
          <div class="md:hidden">
            <%= render Button::Component.new(label: "Stats", behavior: :navigation, link_url: stats_path, style: :menu_item) %>
            <div class="border-t border-gray-700 my-1"></div>
          </div>
          <%= render Button::Component.new(label: "Profile", behavior: :navigation, link_url: profile_path, style: :menu_item) %>
          <% if Current.user.admin? %>
            <div class="border-t border-gray-700 my-1"></div>
            <%= render Button::Component.new(label: "Admin", behavior: :navigation, link_url: "/admin", style: :menu_item) %>
            <%= render Button::Component.new(label: "Jobs", behavior: :navigation, link_url: "/admin/jobs", style: :menu_item) %>
            <%= render Button::Component.new(label: "Feature Flags", behavior: :navigation, link_url: "/admin/flipper", style: :menu_item) %>
            <%= render Button::Component.new(label: "Maintenance", behavior: :navigation, link_url: "/admin/maintenance_tasks", style: :menu_item) %>
          <% end %>
          <div class="border-t border-gray-700 my-1"></div>
          <%= button_to "Sign Out", session_path, method: :delete, class: "w-full text-left px-4 py-2 text-sm text-red-400 hover:bg-gray-700" %>
        <% end %>
      <% else %>
        <div class="flex items-center space-x-1">
          <%= render Button::Component.new(label: "Log in", behavior: :navigation, link_url: new_session_path, style: :secondary) %>
          <%= render Button::Component.new(label: "Sign up", behavior: :navigation, link_url: new_registration_path, style: :gradient) %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
