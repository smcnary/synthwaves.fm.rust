<nav class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
  <div class="container mx-auto py-3">
    <div class="flex items-center justify-between">
      <!-- Left side: App name -->
      <div class="flex items-center space-x-1">
        <%= link_to root_path, class: "text-xl font-semibold text-gray-900 dark:text-white hover:text-gray-700 dark:hover:text-gray-300" do %>
          Groovy Tunes
        <% end %>
      </div>
      <!-- Right side: User Dropdown or Auth links -->
      <% if authenticated? %>
        <details class="relative">
          <summary class="flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white cursor-pointer list-none">
            <%= Current.user.email_address %>
            <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="absolute right-0 mt-2 w-48 bg-white dark:bg-gray-800 rounded-md shadow-lg border border-gray-200 dark:border-gray-700 py-1 z-50">
            <%= link_to "Profile", profile_path, class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700" %>
            <% if Current.user.admin? %>
              <div class="border-t border-gray-200 dark:border-gray-700 my-1"></div>
              <%= link_to "Admin", "/admin", class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700" %>
              <%= link_to "Jobs", "/admin/jobs", class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700" %>
              <%= link_to "Feature Flags", "/admin/flipper", class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700" %>
              <%= link_to "Maintenance", "/admin/maintenance_tasks", class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700" %>
            <% end %>
            <div class="border-t border-gray-200 dark:border-gray-700 my-1"></div>
            <%= button_to "Sign Out", session_path, method: :delete, data: { turbo_method: :delete }, class: "w-full text-left px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-gray-100 dark:hover:bg-gray-700" %>
          </div>
        </details>
      <% else %>
        <div class="flex items-center space-x-1">
          <%= link_to "Log in", new_session_path, class: "px-3 py-2 rounded-md text-sm font-medium bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-gray-100 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors duration-200" %>
          <%= link_to "Sign up", new_registration_path, class: "px-4 py-2 rounded-lg text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-colors duration-200" %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
