<div class="w-full max-w-2xl">
  <div class="mb-6">
    <%= link_to "&larr; Library".html_safe, library_path, class: "text-neon-cyan hover:underline" %>
  </div>

  <h1 class="text-2xl font-bold font-display text-white mb-6">Downloads</h1>

  <%= turbo_stream_from "downloads_#{Current.user.id}" %>

  <div id="downloads-list" class="space-y-4">
    <% if @downloads.any? %>
      <% @downloads.each do |download| %>
        <%= render "downloads/status", download: download %>
      <% end %>
    <% else %>
      <p class="text-gray-400">No downloads yet.</p>
    <% end %>
  </div>
</div>
